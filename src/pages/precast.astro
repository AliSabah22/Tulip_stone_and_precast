---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTASection from '../components/CTASection.astro';

const categories = [
  {
    id: 'residential',
    label: 'Residential',
    title: 'Residential Precast',
    description: 'For homeowners who want lasting beauty and structural integrity. Our residential precast elements include front porch systems, garden and retaining walls, architectural steps, decorative column bases, and custom exterior elements. Each piece is fabricated to match your project drawings.',
    features: [
      'Front porch systems and platforms',
      'Garden walls and retaining walls',
      'Architectural steps and landings',
      'Decorative column bases and pier caps',
      'Custom exterior accent elements',
    ],
    gradient: 'var(--grad-limestone)',
    imageSrc: '/pictures/Residential.jpg',
    imageAlt: 'Residential precast concrete elements — Tulip Precast Brampton',
    customCTA: true,
  },
  {
    id: 'commercial-industrial',
    label: 'Commercial & Industrial',
    title: 'Commercial & Industrial Precast',
    description: 'Scale, precision, and engineering-grade performance for commercial and industrial construction. Our capabilities span architectural facade elements, building entrance systems, large-format platforms, structural components, and custom precast elements — coordinated with your structural engineer and architect.',
    features: [
      'Architectural facade panels and cladding',
      'Commercial entrance systems and steps',
      'Large-format steps, platforms, and plazas',
      'Structural precast components',
      'High-load capacity specifications',
      'Full shop drawing package included',
    ],
    gradient: 'var(--grad-exterior)',
    imageSrc: '/pictures/stone%20texture%202.jpg',
    imageAlt: 'Commercial and industrial precast concrete — Tulip Precast',
    comingSoon: true,
  },
];

const processSteps = [
  { num: '01', title: 'Contact',       body: 'Email office@tulipprecast.com or call 647-534-7755 with your project details.' },
  { num: '02', title: 'Estimate',      body: 'Submit project information for pricing from our estimating team.' },
  { num: '03', title: 'Shop Drawings', body: 'Our drafting team collaborates with your contractor or architect to address every specification.' },
  { num: '04', title: 'Approval',      body: 'Drawings forwarded to architect or responsible party. Phone confirmation required on return.' },
  { num: '05', title: 'Fabrication',   body: 'Upon receipt of signed proposal and deposit, your project enters our fabrication schedule.' },
  { num: '06', title: 'Delivery',      body: 'Your custom precast elements delivered to site, ready for installation.' },
];
---

<BaseLayout
  title="Precast Concrete Fabrication | GTA | Tulip Precast"
  description="Custom precast concrete in Brampton, ON. Residential, commercial, and industrial elements to specification. Serving the GTA. Ontario Made."
  pageClass="page-precast"
>

  <Hero
    eyebrow="CONCRETE PRECAST · CUSTOM FABRICATION · BRAMPTON, ON"
    headline="Concrete Precast."
    headlineItalic="Precision Built."
    subheading="Custom precast concrete elements for residential, commercial, and industrial projects. Fabricated in Ontario. Delivered across Canada & USA."
    primaryCTA="REQUEST A QUOTE"
    primaryCTAHref="/contact"
    secondaryCTA="VIEW PORTFOLIO"
    secondaryCTAHref="/portfolio?filter=precast"
    size="short"
    backgroundGradient="var(--grad-product)"
    imageSrc="/pictures/lifestyle.jpg"
    imageAlt="Precast concrete texture — Tulip Precast custom fabrication"
  />

  <!-- Category sections -->
  <div class="precast-content">
    <div class="container">

      {categories.map((cat, i) => (
        <section id={cat.id} class="precast-section reveal" aria-label={cat.title}>
          <div class={`precast-grid ${i % 2 === 1 ? 'precast-grid--reverse' : ''}`}>
            <div class="precast-image reveal">
              {cat.imageSrc ? (
                <img
                  src={cat.imageSrc}
                  alt={cat.imageAlt || cat.title}
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="precast-real-img"
                />
              ) : (
                <div class="precast-placeholder" style={`background: ${cat.gradient}`} aria-hidden="true">
                  <span class="placeholder-label">[ Photography ]</span>
                </div>
              )}
            </div>
            <div class="precast-text">
              <p class="section-label precast-label">{cat.label}</p>
              <h2 class="precast-title">{cat.title}</h2>
              <div class="draw-line precast-rule" aria-hidden="true"></div>
              <p class="precast-description">{cat.description}</p>
              <ul class="precast-features" role="list">
                {cat.features.map((f) => (
                  <li class="precast-feature-item">
                    <span class="feature-mark" aria-hidden="true">—</span>
                    <span>{f}</span>
                  </li>
                ))}
              </ul>
              {cat.customCTA && (
                <div class="precast-custom-cta">
                  <span class="precast-custom-cta-label">We Can Make What You Want</span>
                  <p class="precast-custom-cta-body">Have a unique design in mind? Bring us any idea — sketch, photo, or drawing — and we'll fabricate it exactly to your specification.</p>
                  <a href="/contact?product=custom-residential" class="btn btn-outlined-dark btn-magnetic">
                    Tell Us About Your Project
                  </a>
                </div>
              )}
              {cat.comingSoon ? (
                <span class="btn btn-primary" style="opacity:0.5;cursor:default;pointer-events:none;letter-spacing:var(--ls-wider);">Coming Soon</span>
              ) : (
                <a href={`/contact?product=${cat.id}-precast`} class="btn btn-primary btn-magnetic">
                  Request a Quote for {cat.title}
                </a>
              )}
            </div>
          </div>
        </section>
      ))}

      <!-- Process section -->
      <section id="process" class="process-section">
        <SectionHeader
          label="Our Process"
          title="How Ordering Works."
          subtitle="From first contact to delivery — a clear, coordinated process that protects your timeline and budget."
          align="center"
        />

        <div class="process-timeline">
          {processSteps.map((step, i) => (
            <div class="process-step reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="process-step-number">{step.num}</div>
              <div class="process-step-connector" aria-hidden="true"></div>
              <h3 class="process-step-title">{step.title}</h3>
              <p class="process-step-body">{step.body}</p>
            </div>
          ))}
        </div>
      </section>

    </div>
  </div>

  <CTASection
    background="dark"
    headline="Need a precast estimate?"
    subheading="Submit your drawings or project details and our team will prepare a comprehensive quotation."
    buttonText="REQUEST A QUOTE"
    buttonHref="/contact"
  />

</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .precast-content {
    background: var(--limestone-cream);
    padding: var(--space-2xl) 0;
  }

  .precast-section {
    padding: var(--space-2xl) 0;
    border-bottom: 1px solid var(--sand-light);
  }

  /* ── Content grid ──────────────────────────────────── */

  .precast-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .precast-grid--reverse {
    direction: rtl;
  }

  .precast-grid--reverse > * {
    direction: ltr;
  }

  .precast-image {
    overflow: hidden;
  }

  .precast-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .precast-real-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .precast-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .precast-label {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--warm-sand);
    max-width: none;
  }

  .precast-title {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 400;
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-tight);
    color: var(--stone-dark);
  }

  .precast-rule {
    width: 40px;
    height: 1px;
    background: var(--warm-sand);
  }

  .precast-description {
    font-size: var(--text-body);
    line-height: var(--lh-body);
    color: var(--stone-mid);
    max-width: 55ch;
  }

  .precast-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .precast-feature-item {
    display: flex;
    gap: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    color: var(--stone-mid);
    line-height: var(--lh-body);
  }

  .feature-mark {
    color: var(--warm-sand);
    flex-shrink: 0;
  }

  /* ── Custom CTA callout ────────────────────────────── */

  .precast-custom-cta {
    background: var(--cream-dark);
    border-left: 3px solid var(--warm-sand);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .precast-custom-cta-label {
    font-family: var(--font-serif);
    font-size: var(--text-subtitle);
    font-weight: 400;
    color: var(--stone-dark);
    line-height: var(--lh-heading);
    font-style: italic;
  }

  .precast-custom-cta-body {
    font-size: var(--text-small);
    line-height: var(--lh-body);
    color: var(--stone-mid);
    max-width: 48ch;
  }

  /* ── Process ───────────────────────────────────────── */

  .process-section {
    padding: var(--space-2xl) 0;
  }

  .process-timeline {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-md);
    position: relative;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-lg);
    position: relative;
  }

  .process-step::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--sand-light);
  }

  .process-step-number {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 300;
    color: var(--warm-sand);
    line-height: 1;
    letter-spacing: var(--ls-tight);
    margin-bottom: 4px;
  }

  .process-step-connector {
    position: absolute;
    top: 0;
    left: 0;
    width: 8px;
    height: 8px;
    background: var(--warm-sand);
    border-radius: 50%;
    transform: translate(-1px, -4px);
  }

  .process-step-title {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--stone-dark);
  }

  .process-step-body {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    line-height: var(--lh-body);
    color: var(--stone-mid);
    max-width: 100%;
  }

  /* ── Responsive ────────────────────────────────────── */

  @media (max-width: 1024px) {
    .process-timeline {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .precast-grid,
    .precast-grid--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .process-timeline {
      grid-template-columns: 1fr;
    }

    .process-step::before {
      left: 20px;
      right: auto;
      top: 0;
      width: 1px;
      height: 100%;
      right: auto;
    }
  }
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What precast concrete products does Tulip Precast fabricate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We fabricate a wide range of precast elements for residential, commercial, and industrial applications — including steps, lintels, sills, caps, pads, retaining wall blocks, light pole bases, and custom structural elements."
      }
    },
    {
      "@type": "Question",
      "name": "Can you match custom dimensions and profiles for precast concrete?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. All precast products can be fabricated to custom dimensions, profiles, and finishes. Provide your drawings or specifications and we will quote accordingly."
      }
    },
    {
      "@type": "Question",
      "name": "What is the delivery area for precast products?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We deliver throughout the Greater Toronto Area and surrounding regions, including Brampton, Mississauga, Oakville, Burlington, Hamilton, Toronto, Vaughan, and Markham. Contact us for delivery pricing and scheduling."
      }
    },
    {
      "@type": "Question",
      "name": "What concrete strength do you use for precast elements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our precast elements are fabricated with 35 MPa or higher compressive strength concrete, meeting or exceeding CSA standards for structural precast applications."
      }
    },
    {
      "@type": "Question",
      "name": "Do you handle large commercial or industrial precast orders?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We are equipped for commercial and industrial precast fabrication including large-format elements, high-volume runs, and project-specific requirements. Contact us to discuss your project."
      }
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tulipprecast.com" },
    { "@type": "ListItem", "position": 2, "name": "Precast Products", "item": "https://www.tulipprecast.com/precast" }
  ]
}
</script>
