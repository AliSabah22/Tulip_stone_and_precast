---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTASection from '../components/CTASection.astro';

const gfrcSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Glass Fiber Reinforced Concrete (GFRC) Fabrication",
  "description": "Premium GFRC fabrication for architectural facades, feature walls, fireplace surrounds, and custom sculptural elements across the Greater Toronto Area. Ontario Made.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Tulip Limestone · Precast",
    "url": "https://www.tulipprecast.com",
    "telephone": ["647-534-7755", "905-796-0110"],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "98 Rutherford Rd Unit 2C",
      "addressLocality": "Brampton",
      "addressRegion": "ON",
      "postalCode": "L6W 3J5",
      "addressCountry": "CA"
    }
  },
  "areaServed": "Greater Toronto Area",
  "serviceType": "GFRC Architectural Fabrication",
  "url": "https://www.tulipprecast.com/gfrc"
});
---

<BaseLayout
  title="GFRC Fabrication | Glass Fiber Reinforced Concrete | Tulip Precast"
  description="Premium GFRC (Glass Fiber Reinforced Concrete) fabrication for architectural facades, feature walls, fireplace surrounds, and custom sculptural elements across the Greater Toronto Area. Ontario Made."
  pageClass="page-gfrc"
  additionalSchema={gfrcSchema}
>

  <!-- Section 1: Hero -->
  <Hero
    eyebrow="ONTARIO MADE · GFRC FABRICATION · BRAMPTON, ON"
    headline="Glass Fiber Reinforced."
    headlineItalic="Architecturally Precise."
    subheading="GFRC — an advanced composite of glass fibers and cementitious matrix. Up to 75% lighter than standard precast, with unlimited design flexibility for facades, feature walls, and sculptural elements."
    primaryCTA="REQUEST A QUOTE"
    primaryCTAHref="/contact?service=gfrc"
    secondaryCTA="VIEW PORTFOLIO"
    secondaryCTAHref="/portfolio"
    size="short"
    backgroundGradient="var(--grad-product)"
    imageSrc="/pictures/stone%20texture%202.jpg"
    imageAlt="GFRC architectural panel texture — Tulip Precast Brampton"
  />

  <!-- Section 2: Material Introduction -->
  <section class="gfrc-intro" aria-label="About GFRC">
    <div class="gfrc-container">
      <SectionHeader
        label="The Material"
        title="A New Standard in"
        titleItalic="Architectural Concrete."
        subtitle="Glass Fiber Reinforced Concrete combines the aesthetic of traditional cast stone with a dramatically reduced weight profile and expanded geometric possibility. Fabricated in Brampton, Ontario."
        align="center"
      />

      <div class="gfrc-stats">
        <div class="gfrc-stat reveal reveal-delay-1">
          <span class="gfrc-stat-num">75%</span>
          <span class="gfrc-stat-rule draw-line" aria-hidden="true"></span>
          <span class="gfrc-stat-label">Lighter than standard precast</span>
        </div>
        <div class="gfrc-stat reveal reveal-delay-2">
          <span class="gfrc-stat-num">18mm</span>
          <span class="gfrc-stat-rule draw-line" aria-hidden="true"></span>
          <span class="gfrc-stat-label">Typical panel thickness</span>
        </div>
        <div class="gfrc-stat reveal reveal-delay-3">
          <span class="gfrc-stat-num">AR</span>
          <span class="gfrc-stat-rule draw-line" aria-hidden="true"></span>
          <span class="gfrc-stat-label">Alkali-resistant glass fibers</span>
        </div>
        <div class="gfrc-stat reveal reveal-delay-4">
          <span class="gfrc-stat-num">∞</span>
          <span class="gfrc-stat-rule draw-line" aria-hidden="true"></span>
          <span class="gfrc-stat-label">Form complexity — no limitation</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Why GFRC — dark background, 2×2 grid -->
  <section class="gfrc-why" aria-label="Why choose GFRC">
    <div class="gfrc-container">
      <SectionHeader
        label="Material Properties"
        title="Why GFRC."
        align="center"
      />

      <div class="gfrc-why-grid">

        <div class="gfrc-why-card reveal reveal-delay-1">
          <span class="gfrc-why-num" aria-hidden="true">01</span>
          <h3 class="gfrc-why-title">Structural Strength</h3>
          <span class="gfrc-why-rule" aria-hidden="true"></span>
          <p class="gfrc-why-body">Alkali-resistant glass fibers distributed through the cementitious matrix provide tensile and flexural strength that far exceeds plain concrete. GFRC panels handle impact, thermal cycling, and structural loading with consistent performance over decades.</p>
        </div>

        <div class="gfrc-why-card reveal reveal-delay-2">
          <span class="gfrc-why-num" aria-hidden="true">02</span>
          <h3 class="gfrc-why-title">Reduced Weight</h3>
          <span class="gfrc-why-rule" aria-hidden="true"></span>
          <p class="gfrc-why-body">At 18–25mm thickness, GFRC panels weigh 25–50 kg/m² — compared to 250+ kg/m² for traditional precast. This reduction opens up facade applications on structures where full-depth concrete would require significant structural reinforcement or is simply not feasible.</p>
        </div>

        <div class="gfrc-why-card reveal reveal-delay-3">
          <span class="gfrc-why-num" aria-hidden="true">03</span>
          <h3 class="gfrc-why-title">Design Freedom</h3>
          <span class="gfrc-why-rule" aria-hidden="true"></span>
          <p class="gfrc-why-body">The spray-up and premix production methods allow GFRC to conform to complex three-dimensional forms, sharp arrises, deep relief textures, and large-format panels. Profiles and geometries that are impractical or impossible in standard precast become achievable.</p>
        </div>

        <div class="gfrc-why-card reveal reveal-delay-4">
          <span class="gfrc-why-num" aria-hidden="true">04</span>
          <h3 class="gfrc-why-title">Durability</h3>
          <span class="gfrc-why-rule" aria-hidden="true"></span>
          <p class="gfrc-why-body">GFRC resists freeze-thaw cycles, moisture penetration, UV exposure, and surface abrasion. The dense cementitious surface holds pigment colour with excellent long-term stability. Suitable for both interior and exterior applications in Ontario's climate.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Section 4: Applications — 6 alternating sections with images -->
  <section class="gfrc-applications" aria-label="GFRC applications">
    <div class="gfrc-container">
      <SectionHeader
        label="Applications"
        title="Where GFRC"
        titleItalic="Excels."
        subtitle="From residential facade cladding to large-scale commercial installations — six primary applications where GFRC delivers results that standard precast cannot."
      />
    </div>

    <!-- Application 1: Architectural Facades -->
    <div class="gfrc-app gfrc-app--normal">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Architectural%20Facades.jpg"
          alt="GFRC architectural facade panel — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">01</span>
        <h3 class="gfrc-app-title">Architectural Facades</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">Large-format GFRC cladding panels deliver the weight and presence of stone on exterior facades at a fraction of the structural load. Custom profiles, reveals, and surface textures are produced to specification and installed directly onto the building envelope. Suitable for residential, commercial, and institutional projects.</p>
        <ul class="gfrc-app-features">
          <li>Large panel formats up to 2400 × 1200mm</li>
          <li>Custom reveals and shadow profiles</li>
          <li>Multiple anchor systems available</li>
          <li>Smooth, textured, and aggregate-exposed finishes</li>
        </ul>
        <a href="/contact?service=gfrc-facade" class="btn btn-outlined-dark btn-sm">Inquire About Facades</a>
      </div>
    </div>

    <!-- Application 2: Feature Walls -->
    <div class="gfrc-app gfrc-app--reversed">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Feature%20Walls.jpg"
          alt="GFRC interior feature wall — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">02</span>
        <h3 class="gfrc-app-title">Feature Walls</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">Interior and exterior feature walls using GFRC achieve the visual depth and material authenticity of stone or carved concrete — installed without structural modification. The lightweight panels allow feature wall applications in lobbies, living areas, courtyards, and facades where traditional masonry weight would be prohibitive.</p>
        <ul class="gfrc-app-features">
          <li>Modular tile and panel formats</li>
          <li>3D relief and sculptural surface options</li>
          <li>Interior and exterior rated</li>
          <li>Continuous or jointed installation patterns</li>
        </ul>
        <a href="/contact?service=gfrc-feature-wall" class="btn btn-outlined-dark btn-sm">Inquire About Feature Walls</a>
      </div>
    </div>

    <!-- Application 3: Fireplace Surrounds -->
    <div class="gfrc-app gfrc-app--normal">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Fireplace%20Surrounds.jpg"
          alt="GFRC fireplace surround — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">03</span>
        <h3 class="gfrc-app-title">Fireplace Surrounds</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">GFRC fireplace surrounds replicate the grandeur of carved limestone or precast concrete at significantly reduced installation complexity. Custom profiles, classical mouldings, and contemporary flat forms are all achievable. The material handles thermal cycling with no cracking or spalling concerns that affect thicker concrete elements.</p>
        <ul class="gfrc-app-features">
          <li>Classical and contemporary profiles</li>
          <li>Custom pilasters, mantels, and hearths</li>
          <li>Thermal-stable cementitious matrix</li>
          <li>Indoor and outdoor fireplaces</li>
        </ul>
        <a href="/contact?service=gfrc-fireplace" class="btn btn-outlined-dark btn-sm">Inquire About Fireplaces</a>
      </div>
    </div>

    <!-- Application 4: Column Wraps & Architectural Elements -->
    <div class="gfrc-app gfrc-app--reversed">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Column%20Wraps%20%26%20Architectural%20Elements.jpg"
          alt="GFRC column wrap architectural element — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">04</span>
        <h3 class="gfrc-app-title">Column Wraps & Architectural Elements</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">GFRC column wraps, pilasters, cornices, and decorative architectural elements provide the visual presence of full-depth stone fabrication without structural support requirements. Column wraps install over existing structural columns — transforming utilitarian supports into architectural features with entasis, fluting, and capital detail.</p>
        <ul class="gfrc-app-features">
          <li>Doric, Ionic, Corinthian, and custom profiles</li>
          <li>Split column wrap systems for retrofit</li>
          <li>Cornices, keystones, and surround elements</li>
          <li>Coordinated finish to match existing stonework</li>
        </ul>
        <a href="/contact?service=gfrc-columns" class="btn btn-outlined-dark btn-sm">Inquire About Column Wraps</a>
      </div>
    </div>

    <!-- Application 5: Landscape & Garden Elements -->
    <div class="gfrc-app gfrc-app--normal">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Landscape%20%26%20Garden%20Elements.jpg"
          alt="GFRC landscape and garden elements — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">05</span>
        <h3 class="gfrc-app-title">Landscape & Garden Elements</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">Planters, water features, garden walls, and decorative landscape elements fabricated in GFRC offer the permanence of concrete with manageable installation weights. Large planters that would be immovable in standard concrete can be positioned and repositioned. The material handles Ontario winters without freeze-thaw damage when properly mixed.</p>
        <ul class="gfrc-app-features">
          <li>Large planters and water features</li>
          <li>Garden wall coping and cap stones</li>
          <li>Decorative pedestals and plinths</li>
          <li>Freeze-thaw rated mix designs</li>
        </ul>
        <a href="/contact?service=gfrc-landscape" class="btn btn-outlined-dark btn-sm">Inquire About Landscape</a>
      </div>
    </div>

    <!-- Application 6: Custom Sculptural Work -->
    <div class="gfrc-app gfrc-app--reversed">
      <div class="gfrc-app-media clip-reveal">
        <img
          src="/GFRC/Custom%20Sculptural%20Work.jpg"
          alt="GFRC custom sculptural elements — Tulip Precast"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
          class="gfrc-app-img"
        />
      </div>
      <div class="gfrc-app-content reveal">
        <span class="gfrc-app-num" aria-hidden="true">06</span>
        <h3 class="gfrc-app-title">Custom Sculptural Work</h3>
        <span class="gfrc-app-rule draw-line" aria-hidden="true"></span>
        <p class="gfrc-app-body">Three-dimensional sculptural elements — figures, abstract forms, bas-relief panels, and site-specific installations — benefit from GFRC's ability to capture fine surface detail from moulds and its structural integrity without internal steel reinforcement. The material is suited to complex geometries that cannot be achieved with conventional casting methods.</p>
        <ul class="gfrc-app-features">
          <li>High-detail surface reproduction from moulds</li>
          <li>Large sculptural forms without internal armature</li>
          <li>Bas-relief and carved-surface panels</li>
          <li>Custom commissions for residential and public art</li>
        </ul>
        <a href="/contact?service=gfrc-sculpture" class="btn btn-outlined-dark btn-sm">Inquire About Custom Work</a>
      </div>
    </div>

  </section>

  <!-- Section 5: Finishes & Colours -->
  <section class="gfrc-finishes" aria-label="GFRC finishes and colours">
    <div class="gfrc-container">
      <SectionHeader
        label="Finishes & Colours"
        title="Surface."
        titleItalic="Refined."
        subtitle="Four standard surface finishes, each available in a broad palette of integral pigment colours. Custom colour matching available on request."
        align="center"
      />

      <div class="gfrc-finish-grid">

        <div class="gfrc-finish-card reveal reveal-delay-1">
          <div class="gfrc-finish-swatch gfrc-finish-swatch--smooth" aria-hidden="true"></div>
          <h4 class="gfrc-finish-title">Smooth Cast</h4>
          <p class="gfrc-finish-desc">Dense, uniform surface with a fine matte texture. Achieved through careful mould preparation and consistent mix application. The most flexible finish for architectural cladding and fireplace elements.</p>
        </div>

        <div class="gfrc-finish-card reveal reveal-delay-2">
          <div class="gfrc-finish-swatch gfrc-finish-swatch--sandblast" aria-hidden="true"></div>
          <h4 class="gfrc-finish-title">Sandblasted</h4>
          <p class="gfrc-finish-desc">Light abrasion opens the aggregate matrix, producing a fine-textured surface that catches directional light and resembles natural stone. Maintains all dimensional precision of the panel beneath.</p>
        </div>

        <div class="gfrc-finish-card reveal reveal-delay-3">
          <div class="gfrc-finish-swatch gfrc-finish-swatch--bush" aria-hidden="true"></div>
          <h4 class="gfrc-finish-title">Bush Hammered</h4>
          <p class="gfrc-finish-desc">Mechanical surface treatment that creates a uniform pitted texture with the tactile quality of hand-dressed stone. Excellent for feature walls and elements where material authenticity is the priority.</p>
        </div>

        <div class="gfrc-finish-card reveal reveal-delay-4">
          <div class="gfrc-finish-swatch gfrc-finish-swatch--exposed" aria-hidden="true"></div>
          <h4 class="gfrc-finish-title">Exposed Aggregate</h4>
          <p class="gfrc-finish-desc">Selected aggregate — limestone, quartz, or granite — is revealed at the surface through retardation and washing. The aggregate species and size determine the final character. Can closely simulate natural stone.</p>
        </div>

      </div>

      <div class="gfrc-colour-callout reveal">
        <div class="gfrc-colour-callout-inner">
          <div class="gfrc-colour-swatches" aria-hidden="true">
            <span class="gfrc-colour-dot" style="background: #F5EDE0;"></span>
            <span class="gfrc-colour-dot" style="background: #C8A882;"></span>
            <span class="gfrc-colour-dot" style="background: #9C8880;"></span>
            <span class="gfrc-colour-dot" style="background: #6B5E56;"></span>
            <span class="gfrc-colour-dot" style="background: #3D3530;"></span>
            <span class="gfrc-colour-dot" style="background: #7A9176;"></span>
          </div>
          <div class="gfrc-colour-text">
            <h4 class="gfrc-colour-title">Integral Colour</h4>
            <p class="gfrc-colour-desc">Pigment is mixed throughout the GFRC matrix — not applied as a coating. Colour is consistent through the full panel depth and does not chip, peel, or fade. Standard palette of twelve colours. Custom colour matching available on consultation.</p>
          </div>
          <a href="/contact?service=gfrc-colour-sample" class="btn btn-outlined-dark btn-sm gfrc-colour-cta">Request Samples</a>
        </div>
      </div>

    </div>
  </section>

  <!-- Section 6: Technical Overview -->
  <section class="gfrc-technical" aria-label="GFRC technical specifications">
    <div class="gfrc-container">
      <SectionHeader
        label="Technical Overview"
        title="Specification."
        titleItalic="Delivered."
        subtitle="Key technical parameters for GFRC fabrication. All specifications subject to project-specific engineering review and mix design confirmation."
      />

      <div class="gfrc-tech-grid">

        <div class="gfrc-tech-card reveal reveal-delay-1">
          <span class="gfrc-tech-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="18" height="18" rx="1" stroke="currentColor" stroke-width="1.2"/>
              <path d="M3 9h18M9 3v18" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          </span>
          <h4 class="gfrc-tech-title">Panel Size</h4>
          <p class="gfrc-tech-spec">Up to 2400 × 1200mm standard. Larger panels available on consultation with additional structural review.</p>
          <ul class="gfrc-tech-list">
            <li>Standard thickness: 12–25mm</li>
            <li>Structural backing frames available</li>
            <li>Max weight: ~50 kg/m²</li>
          </ul>
        </div>

        <div class="gfrc-tech-card reveal reveal-delay-2">
          <span class="gfrc-tech-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.2"/>
              <path d="M12 8v4l3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
          </span>
          <h4 class="gfrc-tech-title">Mix Design</h4>
          <p class="gfrc-tech-spec">Portland cement, fine aggregate, AR glass fiber, polymer admixtures. Mix proportions optimized per application and finish requirement.</p>
          <ul class="gfrc-tech-list">
            <li>5% AR glass fiber by weight (spray-up)</li>
            <li>Water:cement ratio ≤ 0.35</li>
            <li>28-day compressive strength: 40–60 MPa</li>
          </ul>
        </div>

        <div class="gfrc-tech-card reveal reveal-delay-3">
          <span class="gfrc-tech-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
              <path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
            </svg>
          </span>
          <h4 class="gfrc-tech-title">Anchor Systems</h4>
          <p class="gfrc-tech-spec">Concealed steel stud frame, direct adhesive fix, and mechanical anchor systems. Selection based on panel size, substrate, and structural engineering requirements.</p>
          <ul class="gfrc-tech-list">
            <li>Stud frame: standard for large panels</li>
            <li>Adhesive: suitable for panels ≤ 0.5m²</li>
            <li>Shop drawings provided for all anchor layouts</li>
          </ul>
        </div>

        <div class="gfrc-tech-card reveal reveal-delay-4">
          <span class="gfrc-tech-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 3C7.03 3 3 7.03 3 12s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9z" stroke="currentColor" stroke-width="1.2"/>
            </svg>
          </span>
          <h4 class="gfrc-tech-title">Standards & Testing</h4>
          <p class="gfrc-tech-spec">Fabricated to PCI MNL-128 (GFRC) guidelines. Mix and panel samples available upon request for project-specific testing and approval.</p>
          <ul class="gfrc-tech-list">
            <li>PCI MNL-128 fabrication guidelines</li>
            <li>ASTM C947 flexural strength testing</li>
            <li>Freeze-thaw testing per ASTM C666</li>
          </ul>
        </div>

      </div>

      <div class="gfrc-ordering-callout reveal">
        <div class="gfrc-ordering-inner">
          <div class="gfrc-ordering-text">
            <span class="label-section" style="color: rgba(200,168,130,0.7);">How to Order</span>
            <h3 class="gfrc-ordering-title">Start with your drawings.</h3>
            <p class="gfrc-ordering-desc">Submit project drawings, concept sketches, or a description of your requirement. Our team will prepare shop drawings, confirm technical specifications, and provide a detailed quotation. Lead times vary by project scope — contact us early in your design process.</p>
          </div>
          <div class="gfrc-ordering-actions">
            <a href="/contact?service=gfrc" class="btn btn-primary btn-magnetic">Request a Quote</a>
            <a href="/about#process" class="btn btn-outlined gfrc-outlined-light">Our Process →</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Section 7: CTA Band -->
  <CTASection
    background="sage"
    headline="Ready to specify GFRC?"
    subheading="Send us your drawings or concept. Our team will guide you from design through delivery — shop drawings, technical review, and fabrication."
    buttonText="START YOUR GFRC PROJECT"
    buttonHref="/contact?service=gfrc"
  />

</BaseLayout>

<style>
  /* ── Shared container ─────────────────────────────────────── */

  .gfrc-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .label-section {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
    display: block;
    margin-bottom: var(--space-sm);
  }

  /* ── Section 2: Material Intro ───────────────────────────── */

  .gfrc-intro {
    background: var(--limestone-cream);
    padding: var(--space-2xl) 0;
  }

  .gfrc-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .gfrc-stat {
    background: var(--white-warm);
    border: 1px solid var(--cream-dark);
