<BaseLayout
  title="Stone Colours & Finishes | Indiana Limestone Colours | Tulip Precast"
  description="Explore Indiana Limestone colours — Standard Buff, Silver Buff, Standard Gray, and Rustic Gray. Available in all veneer types. Request physical samples from Tulip Precast in Brampton, ON."
  pageClass="page-colours"
>

  <Hero
    eyebrow="18 NATURAL COLOURS · INDIANA LIMESTONE & PREMIUM STONE"
    headline="Stone Colours."
    headlineItalic="Nature's Palette."
    subheading="Eighteen natural stone colours — from warm ivory and golden buff through to jet black. Every colour available in all veneer types. Request physical samples before you order."
    primaryCTA="REQUEST SAMPLES"
    primaryCTAHref="/contact?subject=sample-request"
    secondaryCTA="VIEW VENEERS"
    secondaryCTAHref="#veneers"
    size="xs"
    imageSrc="/pictures/stone%20texture.jpg"
    imageAlt="Indiana Limestone stone colours and texture — Tulip Precast"
  />

  <!-- Colour selector section -->
  <section class="colours-section" aria-label="Indiana Limestone colour palette">
    <div class="container">

      <SectionHeader
        label="Explore Our Palette"
        title="Eighteen Natural Stone Colours."
        subtitle="Indiana Limestone in buff, gray, and black families — plus premium imported stones. All 100% natural, quarried and fabricated to your specification."
      />

      <!-- Swatch grid — photo thumbnails -->
      <div
        class="swatch-grid"
        role="radiogroup"
        aria-label="Limestone colour selector"
      >
        {colours.map((colour, i) => (
          <button
            class:list={['swatch-btn', i === 0 && 'swatch-btn--active']}
            data-colour-id={colour.id}
            aria-pressed={i === 0 ? 'true' : 'false'}
            aria-label={`Select ${colour.name}`}
            type="button"
          >
            <div class="swatch-photo">
              <img
                src={colour.imageSrc}
                alt={colour.imageAlt}
                width="400"
                height="280"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="swatch-img"
              />
              <div class="swatch-overlay" aria-hidden="true">
                <span class="swatch-family">{colour.family}</span>
              </div>
            </div>
            <div class="swatch-meta">
              <span class="swatch-name">{colour.name}</span>
              <span class="swatch-hex" aria-hidden="true" style={`background: ${colour.hex}`}></span>
            </div>
            <div class="swatch-active-bar" aria-hidden="true"></div>
          </button>
        ))}
      </div>

      <!-- Colour detail panels — one per colour, JS toggles active -->
      <div class="detail-wrap" aria-live="polite" aria-atomic="false">
        {colours.map((colour, i) => (
          <ColourDetail colour={colour} isFirst={i === 0} />
        ))}
      </div>

    </div>
  </section>

  <!-- Veneer types section -->
  <section id="veneers" class="veneers-section" aria-label="Veneer types and specifications">
    <div class="container">

      <SectionHeader
        label="Veneer Types"
        title="Specifications &"
        titleItalic="Options."
        subtitle="Five veneer systems — from lightweight thin-bed to full structural depth. Every type available in all four colours."
      />

      <div class="veneer-grid">
        {veneerTypes.map((v, i) => (
          <article class={`veneer-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="veneer-card-image" aria-hidden="true">
              <img
                src={v.imageSrc}
                alt={v.imageAlt}
                width="600"
                height="400"
                loading="lazy"
                decoding="async"
                class="veneer-real-img"
              />
            </div>
            <div class="veneer-card-body">
              <div class="veneer-card-header">
                <p class="veneer-card-subtitle">{v.subtitle} · {v.depth}</p>
                <h3 class="veneer-card-title">{v.title}</h3>
              </div>
              <p class="veneer-description">{v.description}</p>
              <div class="veneer-spec-table">
                {v.specs.map((spec) => (
                  <>
                    <span class="veneer-spec-key">{spec.key}</span>
                    <span class="veneer-spec-val">{spec.val}</span>
                  </>
                ))}
              </div>
              <a href="/contact?product=veneer" class="btn btn-outlined-dark btn-sm">
                Request a Quote
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Sample request CTA -->
  <CTASection
    background="sand"
    headline="Not sure which colour suits your project?"
    subheading="Request a sample pack — we'll send you physical limestone samples in your preferred colours so you can compare them in your actual light conditions."
    buttonText="REQUEST SAMPLES"
    buttonHref="/contact?subject=sample-request"
  />

</BaseLayout>

<style>
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  /* ── Colours section ─────────────────────────────────── */

  .colours-section {
    background: var(--limestone-cream);
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  /* ── Swatch grid ─────────────────────────────────────── */

  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .swatch-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    position: relative;
    text-align: left;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .swatch-btn:hover {
    transform: translateY(-3px);
  }

  .swatch-btn:focus-visible {
    outline: 2px solid var(--warm-sand);
    outline-offset: 3px;
  }

  .swatch-photo {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .swatch-btn--active .swatch-photo,
  .swatch-btn[aria-pressed="true"] .swatch-photo {
    border-color: var(--warm-sand);
  }

  .swatch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .swatch-btn:hover .swatch-img,
  .swatch-btn--active .swatch-img {
    transform: scale(1.06);
  }

  .swatch-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(30, 26, 23, 0.5) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: var(--space-xs) var(--space-sm);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .swatch-btn:hover .swatch-overlay,
  .swatch-btn--active .swatch-overlay {
    opacity: 1;
  }

  .swatch-family {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
  }

  .swatch-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xs) 0;
    gap: var(--space-xs);
  }

  .swatch-name {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 400;
    letter-spacing: var(--ls-wide);
    color: var(--stone-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .swatch-btn--active .swatch-name,
  .swatch-btn[aria-pressed="true"] .swatch-name {
    color: var(--warm-sand);
  }

  .swatch-hex {
    width: 14px;
    height: 14px;
    border: 1px solid var(--cream-dark);
    flex-shrink: 0;
    border-radius: 50%;
  }

  /* Active bottom bar */
  .swatch-active-bar {
    height: 2px;
    background: var(--warm-sand);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .swatch-btn--active .swatch-active-bar,
  .swatch-btn[aria-pressed="true"] .swatch-active-bar {
    transform: scaleX(1);
  }

  /* ── Detail wrap ─────────────────────────────────────── */

  .detail-wrap {
    margin-top: var(--space-lg);
  }

  /* ── Veneers section ─────────────────────────────────── */

  .veneers-section {
    background: var(--cream-dark);
    padding: var(--space-2xl) 0;
  }

  .veneer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .veneer-card {
    background: var(--white-warm);
    border: 1px solid var(--cream-dark);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .veneer-card:hover {
    border-color: var(--sand-light);
    transform: translateY(-4px);
  }

  .veneer-card-image {
    overflow: hidden;
  }

  .veneer-real-img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .veneer-card:hover .veneer-real-img {
    transform: scale(1.04);
  }

  .veneer-card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    flex: 1;
  }

  .veneer-card-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .veneer-card-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
    max-width: none;
  }

  .veneer-card-title {
    font-family: var(--font-serif);
    font-size: var(--text-subtitle);
    font-weight: 400;
    color: var(--stone-dark);
    line-height: var(--lh-heading);
  }

  .veneer-description {
    font-size: var(--text-small);
    line-height: var(--lh-body);
    color: var(--stone-mid);
    max-width: 100%;
  }

  .veneer-spec-table {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 16px;
    margin: var(--space-xs) 0;
  }

  .veneer-spec-key {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--ls-wide);
    color: var(--stone-light);
    max-width: none;
  }

  .veneer-spec-val {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--stone-mid);
    max-width: none;
  }

  /* ── Responsive ──────────────────────────────────────── */

  @media (max-width: 1200px) {
    .swatch-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 1024px) {
    .swatch-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .veneer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .swatch-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xs);
    }

    .veneer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Colour panel switcher -->
<script>
  (function () {
    const swatches = document.querySelectorAll<HTMLButtonElement>('.swatch-btn');
    const panels   = document.querySelectorAll<HTMLElement>('[data-colour-panel]');

    if (swatches.length === 0) return;

    function activate(id: string) {
      swatches.forEach((btn) => {
        const isMatch = btn.dataset.colourId === id;
        btn.setAttribute('aria-pressed', isMatch ? 'true' : 'false');
        btn.classList.toggle('swatch-btn--active', isMatch);
      });

      panels.forEach((panel) => {
        const isMatch = panel.dataset.colourPanel === id;
        panel.classList.toggle('cd--active', isMatch);
        panel.setAttribute('aria-hidden', isMatch ? 'false' : 'true');
      });
    }

    swatches.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.colourId;
        if (id) activate(id);
      });

      btn.addEventListener('keydown', (e: KeyboardEvent) => {
        const list = Array.from(swatches);
        const i    = list.indexOf(btn);
        let target = -1;

        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          e.preventDefault();
          target = (i + 1) % list.length;
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          e.preventDefault();
          target = (i - 1 + list.length) % list.length;
        } else if (e.key === 'Home') {
          e.preventDefault();
          target = 0;
        } else if (e.key === 'End') {
          e.preventDefault();
          target = list.length - 1;
        }

        if (target >= 0) {
          const id = list[target].dataset.colourId;
          if (id) {
            activate(id);
            list[target].focus();
          }
        }
      });
    });
  })();
</script>

