---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProductCard from '../components/ProductCard.astro';
import PortfolioItem from '../components/PortfolioItem.astro';
import CTASection from '../components/CTASection.astro';

const processSteps = [
  {
    num: '01',
    title: 'Contact',
    body: 'Email office@tulipprecast.com or call 647-534-7755 to discuss your project.',
  },
  {
    num: '02',
    title: 'Estimate',
    body: 'Submit project details to our estimator for accurate pricing.',
  },
  {
    num: '03',
    title: 'Shop Drawings',
    body: 'Our drafting team collaborates with your architect or contractor on every detail.',
  },
  {
    num: '04',
    title: 'Approval',
    body: 'Drawings forwarded for approval. Phone confirmation required on return.',
  },
  {
    num: '05',
    title: 'Fabrication',
    body: 'Upon signed proposal and deposit, your project enters our schedule.',
  },
  {
    num: '06',
    title: 'Delivery',
    body: 'Custom limestone or precast elements delivered to site, ready for installation.',
  },
];
---

<BaseLayout
  title="Tulip Limestone · Precast | Indiana Limestone Fabrication"
  description="Premium Indiana Limestone fabrication and concrete precast for residential, commercial, and industrial projects across Canada & US. Ontario Made certified."
  pageClass="page-home"
  loadParticles={true}
>

  <!-- Section 01: Hero -->
  <Hero
    size="full"
    videoSrc="/video/Stone%20video.mp4"
    posterSrc="/pictures/hero%20image.jpg"
    imageAlt="Indiana limestone estate with Corinthian columns and balustrades, Greater Toronto Area"
    eyebrow="ONTARIO MADE · LIMESTONE & PRECAST"
    headline="Crafted by Nature."
    headlineItalic="Perfected by Design."
    subheading="Indiana Limestone fabrication and concrete precast for residential, commercial, and industrial projects across Canada & US."
    primaryCTA="REQUEST A QUOTE"
    primaryCTAHref="/contact"
    secondaryCTA="VIEW OUR WORK"
    secondaryCTAHref="/portfolio"
    accentCount="500+"
    accentLabel="PROJECTS"
  />

  <!-- Section 02: Trust Bar -->
  <TrustBar />

  <!-- Section 03: Brand Statement -->
  <section class="section-statement" aria-label="Indiana Limestone heritage">
    <div class="section-container">
      <div class="section-statement__inner">

        <!-- Video: full width on top -->
        <div class="statement-video-frame reveal">
          <video
            class="statement-video"
            src="/video/detialed%20limesonte.mp4"
            autoplay
            muted
            loop
            playsinline
            aria-label="Indiana Limestone fabrication detail"
          ></video>
        </div>

        <!-- Text: below the video -->
        <div class="statement-below reveal">
          <div class="statement-below-left">
            <span class="label-section">Indiana Limestone · Natural Stone Fabrication</span>
            <h2 class="statement-headline">
              The same stone as the<br />
              <em>Empire State Building.</em>
            </h2>
            <span class="statement-rule draw-line" aria-hidden="true"></span>
          </div>

          <div class="statement-below-right">
            <p class="statement-body">
              Indiana Limestone has been prized for over 150 years for its workability, durability, and capacity to hold crisp architectural detail. The same geological formation supplied stone for the Empire State Building, the National Cathedral, and the Biltmore Estate. Now available for your project, fabricated right here in Ontario.
            </p>

            <div class="statement-pills" aria-label="Key facts">
              <div class="statement-pill reveal reveal-delay-1">
                <span class="statement-pill-stat">1,000+</span>
                <span class="statement-pill-label">Years trusted</span>
              </div>
              <div class="statement-pill reveal reveal-delay-2">
                <span class="statement-pill-stat">100%</span>
                <span class="statement-pill-label">Natural stone</span>
              </div>
              <div class="statement-pill reveal reveal-delay-3">
                <span class="statement-pill-stat">Ontario</span>
                <span class="statement-pill-label">Made certified</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Section 04: Category Grid -->
  <section class="section section--light section-categories" aria-label="Product categories">
    <div class="section-container">
      <SectionHeader
        label="Our Specialties"
        title="Two Crafts."
        titleItalic="One Standard."
        subtitle="Indiana Limestone fabrication and concrete precast — each produced with the same commitment to precision, permanence, and considered design."
      />

      <div class="category-grid">
        <a href="/limestone" class="category-tile reveal reveal-delay-1">
          <span class="category-tile-label">Natural Stone</span>
          <h3 class="category-tile-title">Limestone Products</h3>
          <p class="category-tile-desc">Columns, balusters, veneers, pavers, carving, and more. Custom shop drawings for every specification.</p>
          <span class="category-tile-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/precast" class="category-tile reveal reveal-delay-2">
          <span class="category-tile-label">Concrete</span>
          <h3 class="category-tile-title">Precast Products</h3>
          <p class="category-tile-desc">Residential, commercial, and industrial precast elements built precisely to specification.</p>
          <span class="category-tile-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/services" class="category-tile reveal reveal-delay-3">
          <span class="category-tile-label">Full Service</span>
          <h3 class="category-tile-title">Custom Services</h3>
          <p class="category-tile-desc">GFRC panels, landscaping, fireplace design, 3D wall art, sculpturing, and complete design services.</p>
          <span class="category-tile-arrow" aria-hidden="true">→</span>
        </a>

        <a href="/colours" class="category-tile reveal reveal-delay-4">
          <span class="category-tile-label">Materials</span>
          <h3 class="category-tile-title">Colours &amp; Finishes</h3>
          <p class="category-tile-desc">Fifteen Indiana Limestone colours plus six veneer types. Request physical samples.</p>
          <span class="category-tile-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- GFRC Feature Strip -->
  <div class="gfrc-feature-strip reveal">
    <div class="gfrc-strip-inner">
      <div class="gfrc-strip-text">
        <span class="label-section" style="color: rgba(200,168,130,0.7);">Now Available</span>
        <h3 class="gfrc-strip-title">Glass Fiber Reinforced Concrete</h3>
        <p class="gfrc-strip-desc">Lightweight, high-strength GFRC panels for architectural facades, feature walls, fireplace surrounds, and custom sculptural elements. Up to 75% lighter than standard precast — with unlimited design flexibility.</p>
      </div>
      <a href="/gfrc" class="btn gfrc-strip-btn btn-magnetic">Explore GFRC →</a>
    </div>
  </div>

  <!-- Section 05: Featured Products -->
  <section class="section section--cream section-products" aria-label="Featured limestone products">
    <div class="section-container">
      <SectionHeader
        label="Our Products"
        title="Built for"
        titleItalic="Permanence."
        subtitle="Every piece fabricated to your exact specification. Standard profiles and fully custom work available."
      />

      <div class="product-grid">
        <ProductCard
          category="Limestone · Architectural"
          title="Columns"
          description="Handcrafted Indiana Limestone columns in Doric, Ionic, Corinthian, Tuscan, and Composite styles. Custom specifications for every project, crafted with great artistry and precision."
          href="/limestone#columns"
          imageSrc="/pictures/Limestone%20page%20images/columns.jpg"
          imageAlt="Handcrafted Indiana limestone Corinthian columns, Tulip Limestone · Precast"
          imagePosition="center 25%"
        />

        <ProductCard
          category="Limestone · Architectural"
          title="Balusters & Balustrades"
          description="Solid limestone balusters for entryways, balconies, staircases, and pool areas. Visually consistent colour and form throughout your entire project."
          href="/limestone#balusters-balustrades"
          imageSrc="/pictures/Limestone%20page%20images/Balusters-Balustrades.jpg"
          imageAlt="Indiana limestone balusters on residential balcony, Tulip Precast"
          imagePosition="center 40%"
        />

        <ProductCard
          category="Limestone · Cladding"
          title="Veneers"
          description="Thin and full bed depth Indiana Limestone veneers in smooth, split face, and tumbled finishes. No footing required for thin veneer — installs over existing masonry."
          href="/limestone#veneers"
          imageSrc="/pictures/Limestone%20page%20images/Veneers.webp"
          imageAlt="Indiana limestone smooth thin veneer surface, Tulip Precast"
          imagePosition="center 50%"
        />

        <ProductCard
          category="Limestone · Hardscape"
          title="Pavers"
          description="Timeless beauty and exceptional durability for outdoor spaces. Low maintenance, long-lasting, available in a variety of colours, cuts, and textures."
          href="/limestone#pavers"
          imageSrc="/pictures/Limestone%20page%20images/Pavers.jpeg"
          imageAlt="Indiana limestone pavers on residential outdoor terrace, Tulip Precast"
          imagePosition="center 50%"
        />

        <ProductCard
          category="Limestone · Finishing"
          title="Wall Caps"
          description="An elegant finished look for any masonry wall. Cost-effective protection in six standard profiles — Classic, Rounded, Double Wash, Bull Nose, Vintage, and Natural Rockface."
          href="/limestone#wall-caps"
          imageSrc="/pictures/Limestone%20page%20images/wall%20caps.png"
          imageAlt="Indiana limestone wall caps on garden wall, Tulip Precast"
          imagePosition="center 50%"
        />

        <ProductCard
          category="Limestone · Artisan"
          title="Carving"
          description="Custom limestone carving expertise — from intricate architectural ornaments to full sculptural commissions. The stone that holds crisp detail better than any other."
          href="/limestone#carving"
          imageSrc="/pictures/Limestone%20page%20images/carving.jpg"
          imageAlt="Artisan Indiana limestone carving detail, Tulip Limestone · Precast"
          imagePosition="center 40%"
        />
      </div>

      <div class="section-link-row reveal">
        <a href="/limestone" class="btn btn-outlined-dark btn-magnetic">
          View All Limestone Products →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 06: Why Tulip -->
  <section class="section-why" aria-label="Why choose Tulip">
    <div class="section-container">
      <SectionHeader
        label="Why Tulip"
        title="Design-Led Stone Fabrication."
        align="center"
      />

      <div class="why-grid">
        <div class="why-card reveal reveal-delay-1">
          <span class="why-number" aria-hidden="true">01</span>
          <h3 class="why-title">Expertise</h3>
          <span class="why-rule" aria-hidden="true"></span>
          <p class="why-body">Indiana Limestone and Precast specialists with deep material knowledge. We work directly with architects, contractors, and homeowners to bring every specification to life exactly as envisioned.</p>
        </div>

        <div class="why-card reveal reveal-delay-2">
          <span class="why-number" aria-hidden="true">02</span>
          <h3 class="why-title">Process</h3>
          <span class="why-rule" aria-hidden="true"></span>
          <p class="why-body">Custom shop drawings and CNC precision. Our drafting team collaborates closely with your architect to address every detail — eliminating jobsite issues before fabrication begins.</p>
        </div>

        <div class="why-card reveal reveal-delay-3">
          <span class="why-number" aria-hidden="true">03</span>
          <h3 class="why-title">Result</h3>
          <span class="why-rule" aria-hidden="true"></span>
          <p class="why-body">Standard and fully custom solutions, trusted on luxury residences across the Greater Toronto Area. Ontario Made. Built to endure for generations — not just for today.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 07: Portfolio Preview -->
  <section class="section section--light section-portfolio" aria-label="Portfolio preview">
    <div class="section-container">
      <SectionHeader
        label="Our Work"
        title="Recent"
        titleItalic="Projects."
        subtitle="A selection of residential, commercial, and custom limestone and precast projects across the Greater Toronto Area."
      />

      <div class="portfolio-preview-grid">

        <!-- Block 1 -->
        <div class="portfolio-block">
          <PortfolioItem
            size="anchor"
            title="French Château Estate"
            style="Beaux-Arts"
            location="Greater Toronto Area, ON"
            category="residential limestone"
            imageSrc="/porfolio_directory/project_1/0e7b7d6c-dc6e-4ba3-b41e-692ea3a76fa4.jpg"
            imageAlt="Grand Beaux-Arts limestone estate with mansard roof and columns"
            imagePosition="center center"
          />
          <PortfolioItem
            size="small"
            title="Neoclassic Estate Entry"
            style="Neoclassical"
            location="Oakville, ON"
            category="residential limestone"
            imageSrc="/pictures/portofolio%20images/IMG_5917.jpg"
            imageAlt="Neoclassical limestone estate entrance with columns, Oakville Ontario"
            imagePosition="center top"
          />
          <PortfolioItem
            size="small"
            title="Garden Balustrade"
            style="Classical"
            location="Richmond Hill, ON"
            category="residential limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6493%20(2).jpg"
            imageAlt="Indiana limestone garden balustrade on residential terrace"
            imagePosition="center center"
          />
          <PortfolioItem
            size="wide"
            title="Commercial Office Facade"
            style="Contemporary"
            location="Toronto, ON"
            category="commercial limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6535.jpg"
            imageAlt="Contemporary limestone office building facade, Toronto"
            imagePosition="center 40%"
          />
        </div>

        <!-- Block 2 -->
        <div class="portfolio-block">
          <PortfolioItem
            size="anchor"
            title="Column Entrance"
            style="Neoclassical"
            location="Mississauga, ON"
            category="residential limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6545.jpg"
            imageAlt="Indiana limestone column residential entrance, Mississauga"
            imagePosition="center 30%"
          />
          <PortfolioItem
            size="small"
            title="Carved Door Surround"
            style="Artisan"
            location="Brampton, ON"
            category="residential limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6560.jpg"
            imageAlt="Carved Indiana limestone door surround, Brampton"
            imagePosition="center center"
          />
          <PortfolioItem
            size="small"
            title="Pavers Terrace"
            style="Contemporary"
            location="Burlington, ON"
            category="residential precast"
            imageSrc="/pictures/portofolio%20images/IMG_6569.jpg"
            imageAlt="Indiana limestone pavers on residential terrace, Burlington"
            imagePosition="center bottom"
          />
          <PortfolioItem
            size="wide"
            title="Commercial Entry System"
            style="Modern"
            location="Toronto, ON"
            category="commercial precast"
            imageSrc="/pictures/portofolio%20images/IMG_6574.jpg"
            imageAlt="Precast concrete commercial entry system, Toronto"
            imagePosition="center center"
          />
        </div>

        <!-- Block 3 -->
        <div class="portfolio-block">
          <PortfolioItem
            size="anchor"
            title="Artisan Stone Carving"
            style="Artisan"
            location="Oakville, ON"
            category="residential limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6606.jpg"
            imageAlt="Artisan Indiana limestone carving detail, Oakville"
            imagePosition="center center"
          />
          <PortfolioItem
            size="small"
            title="Stone Banding"
            style="Contemporary"
            location="Etobicoke, ON"
            category="commercial limestone"
            imageSrc="/pictures/portofolio%20images/IMG_6621.jpg"
            imageAlt="Indiana limestone banding on commercial masonry, Etobicoke"
            imagePosition="center center"
          />
          <PortfolioItem
            size="small"
            title="Custom Sculpture"
            style="Artisan"
            location="Thornhill, ON"
            category="residential custom"
            imageSrc="/pictures/portofolio%20images/IMG_6654.jpg"
            imageAlt="Custom limestone sculpture, residential garden, Thornhill"
            imagePosition="center 40%"
          />
          <PortfolioItem
            size="wide"
            title="3D Wall Panel Feature"
            style="Modern"
            location="North York, ON"
            category="residential custom"
            imageSrc="/pictures/portofolio%20images/IMG_6660.jpg"
            imageAlt="Handmade concrete 3D wall panel feature, North York"
            imagePosition="center center"
          />
        </div>

      </div>

      <div class="section-link-row reveal">
        <a href="/portfolio" class="btn btn-outlined-dark btn-magnetic">
          View Full Portfolio →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 08: Brand Story -->
  <section class="section-story" aria-label="Brand story">
    <div class="story-container">
      <div class="story-text reveal">
        <span class="label-section">Our Craft</span>

        <h2 class="story-headline">
          Where stone meets<br />
          <em>artisanship.</em>
        </h2>

        <span class="story-rule draw-line" aria-hidden="true"></span>

        <p class="story-body">
          Every piece we fabricate carries the weight of generations of stonemasonry tradition. Indiana Limestone, shaped by hand, finished with precision — the same natural stone used in the Empire State Building, the National Cathedral, and the Biltmore Estate. Now available for your home.
        </p>

        <p class="story-body">
          Based in Brampton, Ontario, we fabricate limestone and precast elements for homeowners, architects, and contractors across the Greater Toronto Area. Every project is approached as if it will stand for generations — because it will.
        </p>

        <a href="/about" class="btn btn-outlined-dark btn-magnetic story-cta">
          Our Story →
        </a>
      </div>

      <div class="story-image reveal">
        <video
          class="story-img"
          src="/video/drill%20carving.mp4"
          autoplay
          muted
          loop
          playsinline
          aria-label="Artisan drilling detail into Indiana Limestone"
        ></video>
      </div>
    </div>
  </section>

  <!-- Section 09: Testimonials -->
  <section class="section section--light section-testimonials" aria-label="Client testimonials">
    <div class="section-container">
      <SectionHeader
        label="Client Stories"
        title="Built on Trust."
        align="center"
      />

      <div class="testimonial-grid">
        <article class="testimonial-card reveal reveal-delay-1">
          <span class="testimonial-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-quote">
            The craftsmanship on our limestone columns exceeded every expectation. The team was meticulous with the shop drawings and kept us informed throughout fabrication. The finished result is exactly what we envisioned.
          </blockquote>
          <footer class="testimonial-footer">
            <p class="testimonial-author">M. Stefanovic</p>
            <p class="testimonial-location">Residential — Oakville, ON</p>
          </footer>
        </article>

        <article class="testimonial-card reveal reveal-delay-2">
          <span class="testimonial-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-quote">
            We have specified Tulip's limestone products on three projects now. Their ability to match existing stone and accommodate custom profiles is unmatched in the GTA. A reliable partner for any architect working with natural stone.
          </blockquote>
          <footer class="testimonial-footer">
            <p class="testimonial-author">D. Marchetti, Architect</p>
            <p class="testimonial-location">Commercial — Toronto, ON</p>
          </footer>
        </article>

        <article class="testimonial-card reveal reveal-delay-3">
          <span class="testimonial-mark" aria-hidden="true">&ldquo;</span>
          <blockquote class="testimonial-quote">
            Our balustrades and paver terrace have transformed the property entirely. Visitors always ask who did the stonework. The quality of the material and the installation speaks for itself every single day.
          </blockquote>
          <footer class="testimonial-footer">
            <p class="testimonial-author">J. Harrison</p>
            <p class="testimonial-location">Residential — Richmond Hill, ON</p>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <!-- Section 10: Process Strip -->
  <section class="section-process" aria-label="How it works">
    <div class="section-container">
      <SectionHeader
        label="Our Process"
        title="Six Steps to"
        titleItalic="Your Stone."
        subtitle="From first contact to final delivery — here is exactly what to expect."
        align="center"
      />

      <div class="process-timeline">
        <div class="process-connector" aria-hidden="true"></div>
        {processSteps.map((step, i) => (
          <div class="process-step reveal" style={`transition-delay: ${i * 80}ms`}>
            <div class="process-circle" aria-hidden="true">
              <span class="process-num">{step.num}</span>
            </div>
            <h3 class="process-title">{step.title}</h3>
            <p class="process-body">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section 11: Ontario Made Strip -->
  <section class="section-ontario" aria-label="Ontario Made certification">
    <div class="section-container">
      <div class="ontario-inner">
        <div class="ontario-badge" aria-label="Ontario Made certified">
          <svg
            width="88"
            height="88"
            viewBox="0 0 88 88"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <circle cx="44" cy="44" r="42" stroke="var(--warm-sand)" stroke-width="1"/>
            <circle cx="44" cy="44" r="36" stroke="var(--warm-sand)" stroke-width="0.5" stroke-dasharray="2 2"/>
            <text
              x="44" y="30"
              font-family="Jost, sans-serif"
              font-size="7"
              font-weight="400"
              letter-spacing="2"
              fill="var(--warm-sand)"
              text-anchor="middle"
            >ONTARIO</text>
            <path
              d="M24 42 C24 37 29 32 36 32 C38 32 39 33 40 34 C38 36 37 38 37 40 C37 45 39 50 44 53 C49 50 51 45 51 40 C51 38 50 36 48 34 C49 33 50 32 52 32 C59 32 64 37 64 42 C64 51 56 60 44 65 C32 60 24 51 24 42Z"
              fill="var(--warm-sand)"
              opacity="0.85"
            />
            <text
              x="44" y="76"
              font-family="Jost, sans-serif"
              font-size="6"
              font-weight="400"
              letter-spacing="2"
              fill="var(--warm-sand)"
              text-anchor="middle"
            >MADE</text>
          </svg>
        </div>

        <div class="ontario-text reveal">
          <span class="label-section">Ontario Made Certified</span>
          <h2 class="ontario-headline">Fabricated Locally. Built to Last.</h2>
          <p class="ontario-body">
            Every product is fabricated right here in Ontario. Choosing Tulip means investing in local craftsmanship, local jobs, and a supply chain you can trust from raw material to finished stone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 12: CTA Band -->
  <CTASection
    headline="Ready to start your project?"
    subheading="Send us your drawings, concepts, or inspiration. Our team will guide you from design to delivery."
    buttonText="REQUEST A FREE QUOTE"
    buttonHref="/contact"
    background="sage"
  />

</BaseLayout>

<style>
  /* ── Shared ──────────────────────────────────────────────── */

  .section {
    padding: var(--space-2xl) 0;
  }

  .section--light { background: var(--limestone-cream); }
  .section--cream { background: var(--cream-dark); }

  .section-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  .label-section {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .section-link-row {
    text-align: center;
    margin-top: var(--space-xl);
  }

  /* ── Section 03: Brand Statement ────────────────────────── */

  .section-statement {
    background: var(--sand-pale);
    padding: var(--space-2xl) 0;
  }

  .section-statement__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  /* Below-video text row */
  .statement-below {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .statement-below-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .statement-below-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .statement-headline {
    font-family: var(--font-serif);
    font-size: clamp(26px, 2.8vw, 40px);
    font-weight: 300;
    color: var(--stone-dark);
    line-height: var(--lh-heading);
    margin: var(--space-sm) 0;
    max-width: 20ch;
  }

  .statement-headline em {
    font-style: italic;
    color: var(--warm-sand);
  }

  .statement-rule {
    display: block;
    height: 1px;
    background: var(--sand-light);
    width: 60px;
    margin: var(--space-md) 0;
    transform-origin: left center;
  }

  .statement-body {
    font-family: var(--font-sans);
    font-size: var(--text-body);
