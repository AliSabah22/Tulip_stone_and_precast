  { name: 'Northern Buff',     hex: '#D4B87A' },
  { name: 'Silver Shadow',     hex: '#B8B4B0' },
  { name: 'Standard Gray',     hex: '#A0A09A' },
  { name: 'Sunset Canyon',     hex: '#C4907A' },
  { name: 'Sterling',          hex: '#D0CCB8' },
