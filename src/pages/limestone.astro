      { name: 'Natural Rockface', description: 'Rough split texture surround, organic character',    imageSrc: '/pictures/door:window%20surround/natural%20rockface.png' },
      { name: 'Custom',           description: 'Any profile or configuration to specification' },
    ],
  },
  {
    id: 'arches',
    num: '06',
    label: 'Limestone · Architectural',
    title: 'Jack Arches',
    imageSrc: '/pictures/Limestone%20page%20images/jack%20arches.jpg',
    imageAlt: 'Indiana limestone jack arch, classic profile, Tulip Precast',
    imagePosition: 'center center',
    description: 'Beautifully cut jack arches define windows and doors with subtle sophistication. These building elements are a cost-effective way to reflect the personal style of your project. Jack arches are designed for either two or three piece installation — and when combined with jambs and a sill, they make a stunning architectural statement.',
    variants: [
      { name: 'Classic',    description: 'Standard flat wedge arch, clean and proportional',    imageSrc: '/pictures/arches/classic.png' },
