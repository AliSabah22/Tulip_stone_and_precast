      { name: 'Classic Bull Nose Sill',     description: 'Rounded leading edge, softened profile',      imageSrc: '/pictures/sills/classic%20Bull%20Nose%20sill.png' },
      { name: 'Conventional Sill',          description: 'Sloped top, standard drainage profile',       imageSrc: '/pictures/sills/Conventional%20Sill.png' },
