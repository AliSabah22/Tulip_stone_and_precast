    const triggers = Array.from(accordion.querySelectorAll<HTMLButtonElement>('[data-accordion-trigger]'));

    function getPanel(trigger: HTMLButtonElement): HTMLElement | null {
      const id = trigger.getAttribute('aria-controls');
      return id ? document.getElementById(id) : null;
    }

    function animateOpen(trigger: HTMLButtonElement, panel: HTMLElement) {
      panel.removeAttribute('hidden');
      panel.style.visibility = 'visible';
      panel.style.maxHeight = '0';
      panel.style.overflow = 'hidden';
      panel.style.transition = 'max-height 500ms cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      // force reflow
      void panel.offsetHeight;
      panel.style.maxHeight = (panel.scrollHeight + 64) + 'px';
      trigger.setAttribute('aria-expanded', 'true');
      panel.addEventListener('transitionend', function onEnd() {
        panel.removeEventListener('transitionend', onEnd);
        panel.style.maxHeight = '';
        panel.style.overflow = '';
      }, { once: true });
    }

    function animateClose(trigger: HTMLButtonElement, panel: HTMLElement) {
      panel.style.overflow = 'hidden';
      panel.style.maxHeight = panel.scrollHeight + 'px';
      panel.style.transition = 'max-height 400ms cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      // force reflow
      void panel.offsetHeight;
      panel.style.maxHeight = '0';
      trigger.setAttribute('aria-expanded', 'false');
      panel.addEventListener('transitionend', function onEnd() {
        panel.removeEventListener('transitionend', onEnd);
        panel.setAttribute('hidden', '');
        panel.style.visibility = 'hidden';
        panel.style.maxHeight = '';
        panel.style.overflow = '';
        panel.style.transition = '';
      }, { once: true });
    }

    function closeAll() {
      triggers.forEach((t) => {
        const p = getPanel(t);
        if (p && t.getAttribute('aria-expanded') === 'true') {
          animateClose(t, p);
        }
      });
    }

    // Initialise all panels collapsed
    triggers.forEach((t) => {
      const p = getPanel(t);
      if (p) {
        p.style.visibility = 'hidden';
      }
    });

    triggers.forEach((trigger, i) => {
      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        const panel  = getPanel(trigger);
        if (!panel) return;
        if (isOpen) {
          animateClose(trigger, panel);
        } else {
          closeAll();
          animateOpen(trigger, panel);
        }
      });

      trigger.addEventListener('keydown', (e: KeyboardEvent) => {
        let target = -1;
        switch (e.key) {
          case 'ArrowDown': e.preventDefault(); target = (i + 1) % triggers.length; break;
          case 'ArrowUp':   e.preventDefault(); target = (i - 1 + triggers.length) % triggers.length; break;
          case 'Home':      e.preventDefault(); target = 0; break;
          case 'End':       e.preventDefault(); target = triggers.length - 1; break;
          case 'Escape': {
            const p = getPanel(trigger);
            if (p && trigger.getAttribute('aria-expanded') === 'true') {
              animateClose(trigger, p);
            }
            break;
          }
        }
        if (target >= 0) triggers[target].focus();
      });
    });

    // Deep-link: auto-open panel if URL hash matches
    document.addEventListener('DOMContentLoaded', () => {
      const hash = window.location.hash.replace('#', '');
      if (!hash) return;
      const panelId = 'fab-panel-' + hash;
      const target  = document.getElementById(panelId);
      const trigger = target ? accordion.querySelector<HTMLButtonElement>(`[aria-controls="${panelId}"]`) : null;
      if (target && trigger) {
        animateOpen(trigger, target);
        setTimeout(() => {
          trigger.closest<HTMLElement>('[data-accordion-item]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  })();
</script>

