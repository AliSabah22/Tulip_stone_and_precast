        specs: [
          ['Footing',   'Not required'],
          ['Heights',   '4", 8", 12"'],
          ['Length',    '24"'],
          ['Depth',     '1¼"'],
          ['Coverage',  '~135 sq ft per ton'],
          ['Colours',   'Full colour blend · Buff · Gray'],
        ],
      },
      {
        type: 'Thin Bed', bed: '¾"–1¼" depth', title: 'Split Face & Tumbled',
        description: 'Thin Indiana Limestone with natural texture and character. Versatile, durable, and fast to install. Available in split face and tumbled finishes — ideal for non-load-bearing walls and renovation cladding.',
        imageSrc: '/pictures/masonry%20detail.jpg', imagePosition: 'center center',
        specs: [
          ['Footing',         'Not required'],
          ['Split Heights',   '2¼", 5", 7¾", 10½"'],
          ['Tumbled Heights', '2"–12"'],
