---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
import ProductSection from '../components/limestone/ProductSection.astro';

type Variant  = { name: string; description?: string; imageSrc?: string };
type SpecRow  = [string, string];
type Benefit  = { title: string; body: string };
type VeneerCard = {
  type: string; bed: string; title: string; description: string;
  imageSrc: string; imagePosition: string; specs: SpecRow[];
};
type Product = {
  id: string; num: string; label: string; title: string;
  imageSrc: string; imageAlt: string; imagePosition: string;
  description: string;
  callout?:  { label: string; body: string };
  variants?: Variant[];
  specs?:    SpecRow[];
  benefits?: Benefit[];
  veneers?:  VeneerCard[];
};

const products: Product[] = [
  {
    id: 'carving',
    num: '01',
    label: 'Limestone · Artisan Craft',
    title: 'Carving',
    imageSrc: '/pictures/Limestone%20page%20images/carving.jpg',
    imageAlt: 'Artisan Indiana limestone carved fireplace surround, custom fabricated by Tulip Limestone · Precast',
    imagePosition: 'center center',
    description: 'Indiana limestone is a remarkable stone — ranging from warm buff to cool blue-gray, prized across generations for its workability and its unique capacity to accept and retain crisp, intricate detail. Today\'s carvers are a diverse group of artisans, many continuing family traditions alongside those who shaped the craft before them. Their skill brings each design to life with timeless precision.',
    callout: {
      label: 'Custom Commission',
      body: 'When ordering a specialty carving, please provide: drawings and specifications, any full-size layouts available, and — for replica work — photographs and measurements of the existing piece. Our team will review and confirm feasibility before quoting.',
    },
  },
  {
    id: 'balusters',
    num: '02',
    label: 'Limestone · Architectural',
    title: 'Balusters & Balustrades',
    imageSrc: '/pictures/Limestone%20page%20images/Balusters-Balustrades.jpg',
    imageAlt: 'Indiana limestone balusters on residential balcony, custom fabricated by Tulip Precast, Brampton Ontario',
    imagePosition: 'center center',
    description: 'Limestone balusters have always been a popular choice — whether for a simple renovation or a complex new construction. Balusters and balustrades are used at entryways, walkways, or as hardscape features. Our solid limestone balusters highlight large and small balconies, patios, staircases, and pool areas. We produce balusters of the highest quality — visually consistent in both colour and form, so your entire project carries a unified architectural character.',
    callout: {
      label: 'Repair & Renovation Matching',
      body: 'Our renovation specialists identify exact matches for existing limestone architectural features. We precisely match the colour, texture, and design of your existing baluster or balustrade — providing an architectural detail that blends seamlessly into the look and feel of the original building. Our expertise in limestone forming, colour matching, and finishing ensures your new balusters integrate perfectly throughout the project.',
    },
  },
  {
    id: 'banding',
    num: '03',
    label: 'Limestone · Masonry',
    title: 'Banding & String Courses',
    imageSrc: '/pictures/Limestone%20page%20images/Banding-String-Courses.jpg',
    imageAlt: 'Indiana limestone banding string course on masonry wall exterior, Tulip Precast',
    imagePosition: 'center center',
    description: 'Banding — also known as string coursing — is one of the most cost-effective ways to add proportion, detail, and visual definition to any masonry structure. Designed to integrate seamlessly with common brick sizes, it creates a refined transitional element that elevates the entire facade. Custom banding profiles are also available for non-standard applications.',
    variants: [
      { name: 'Classic',           description: 'Flat rectangular profile, clean and timeless',    imageSrc: '/pictures/banding/classic.png' },
      { name: 'Bullnose',          description: 'Single rounded leading edge, softened profile',   imageSrc: '/pictures/banding/bull%20nose.png' },
      { name: 'Double Bullnose',   description: 'Both edges rounded, flowing horizontal line',     imageSrc: '/pictures/banding/double%20bull%20nose.png' },
      { name: 'Single Chamfered',  description: 'One angled reveal, adds subtle shadow line',      imageSrc: '/pictures/banding/single%20chamfered.png' },
      { name: 'Double Chamfered',  description: 'Both edges angled, strong directional shadow',    imageSrc: '/pictures/banding/double%20chambered.png' },
      { name: 'Natural Rock Face', description: 'Rough split texture, raw material character',     imageSrc: '/pictures/banding/natural%20rock%20face.png' },
      { name: 'Custom',            description: 'Any profile to specification' },
    ],
  },
  {
    id: 'columns',
    num: '04',
    label: 'Limestone · Architectural',
    title: 'Columns',
    imageSrc: '/pictures/Limestone%20page%20images/columns.jpg',
    imageAlt: 'Handcrafted Indiana limestone Corinthian columns, custom fabricated by Tulip Limestone · Precast, Brampton Ontario',
    imagePosition: 'center 35%',
    description: 'Finely crafted Indiana Limestone columns are the ultimate expression of timeless beauty in natural stone. Every column we deliver is handcrafted by skilled stone artisans to match any classic or contemporary style — to your exact specifications. We know that columns are the showpiece of the project, which is why we craft and deliver each base, shaft, and capital with great artistry and precision.',
    variants: [
      { name: 'Doric',      description: 'Short and heavy with simple round capitals. Strength and dignity.' },
      { name: 'Ionic',      description: 'Slender pillars with large base and signature scrolled capitals.' },
      { name: 'Corinthian', description: 'Slender, fluted columns with intricate carved capitals.' },
      { name: 'Tuscan',     description: 'Plain base and unfluted shaft. Understated and versatile.' },
      { name: 'Composite',  description: 'A refined blend of Ionic scrolls and Corinthian ornamentation.' },
      { name: 'Custom',     description: 'Any classical or contemporary profile to specification.' },
