];

const colours = [
  { name: 'Glacier Buff',      hex: '#D4B896' },
  { name: 'Prairie Blend',     hex: '#9A7D5A' },
  { name: 'Standard Buff',     hex: '#C8A87A' },
  { name: 'Northern Gray',     hex: '#B0AFA8' },
  { name: 'Alabama Fleuri',    hex: '#C8C0B0' },
