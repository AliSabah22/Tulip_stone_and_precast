  {
    id: 'veneers',
    num: '14',
    label: 'Limestone · Cladding',
    title: 'Veneers',
    imageSrc: '/pictures/Limestone%20page%20images/Veneers.webp',
    imageAlt: 'Indiana limestone smooth thin veneer installed on luxury residential exterior, Tulip Precast',
    imagePosition: 'center 50%',
    description: 'Indiana Limestone veneers are the most versatile product in our range — available in thin and full bed depth profiles, each suited to different structural requirements and design intentions. 100% natural stone, no aggregates, no artificial colours. The same geological formation that supplied stone for the Empire State Building, the National Cathedral, and the Biltmore Estate.',
    veneers: [
      {
        type: 'Thin Bed', bed: '1¼" depth', title: 'Smooth',
        description: 'Our most popular thin veneer. Smooth, refined, and consistent — also known as planed, honed, bugged, or circular sanded. Requires no footing or foundation. Installs directly over existing masonry.',
