    label: 'Limestone · Masonry',
    title: 'Water Tables',
    imageSrc: '/pictures/Limestone%20page%20images/water%20table.jpg',
    imageAlt: 'Indiana limestone classic water table profile, Tulip Precast',
    imagePosition: 'center center',
    description: 'The water table is a powerful building element that makes a strong architectural statement. Positioned at the base of a wall or at key horizontal transitions, water tables create seamless continuity to window sills or banding — providing a streamlined, well-proportioned look to any project. Elegant, functional, and built to endure.',
    variants: [
      { name: 'Classic Water Table',          description: 'Clean flat profile, understated elegance',          imageSrc: '/pictures/Water%20Table/Classic%20Water%20Table.png' },
      { name: 'Double Chamfered Water Table', description: 'Both edges angled, strong directional detail',      imageSrc: '/pictures/Water%20Table/Double%20Chamfered%20Water%20Table.png' },
      { name: 'Single Chamfered Water Table', description: 'One angled reveal, refined shadow line',            imageSrc: '/pictures/Water%20Table/Singl%20Chamfered%20Water%20Table.png' },
      { name: 'Ogee Water Table',             description: 'S-curve profile, the most decorative option',       imageSrc: '/pictures/Water%20Table/Ogee%20Water%20Table.png' },
      { name: 'Custom',                       description: 'To specification' },
