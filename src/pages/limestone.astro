      {
        type: 'Full Bed Depth', bed: '3"–4" depth', title: 'Split Face',
        description: 'Split face full bed depth veneer exhibits the beauty of subtle colour and grain variations inherent in natural stone. Adds a sense of permanence and lasting value to any residential or commercial project.',
        imageSrc: '/pictures/hero%20image.jpg', imagePosition: 'center center',
        specs: [
          ['Footing',  'Required'],
          ['Heights',  '2¼", 5", 7¾", 10½"'],
