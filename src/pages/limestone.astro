    ],
  },
  {
    id: 'wall-caps',
    num: '12',
    label: 'Limestone · Finishing',
    title: 'Wall Caps',
    imageSrc: '/pictures/Limestone%20page%20images/wall%20caps.png',
    imageAlt: 'Indiana limestone classic wall cap profile, Tulip Precast',
    imagePosition: 'center center',
    description: 'Wall caps provide a clean, elegant finish to any masonry wall. Beyond their aesthetic appeal, they offer cost-effective protection — enhancing structural integrity while shielding the wall from harsh weather. Available in a variety of stone and precast options, combining durability with timeless design.',
    variants: [
      { name: 'Classic Wall Cap',          description: 'Flat top profile, clean and versatile',           imageSrc: '/pictures/wall%20Caps/Classic%20Wall%20Cap.png' },
      { name: 'Rounded Wall Cap',          description: 'Curved top surface, gentle organic form',          imageSrc: '/pictures/wall%20Caps/Rounded%20Wall%20Cap.png' },
      { name: 'Double Wash Wall Cap',      description: 'Dual-pitched top for superior water shedding',     imageSrc: '/pictures/wall%20Caps/Double%20Wash%20Wall%20Cap.png' },
      { name: 'Bull Nose Wall Cap',        description: 'Rounded leading edge, refined classic detail',     imageSrc: '/pictures/wall%20Caps/bull%20Nose%20Wall%20Cap.png' },
