        specs: [
          ['Footing',  'Required'],
          ['Heights',  '4", 8", 12", 16"'],
          ['Length',   '24" or 36"'],
          ['Depth',    '4"'],
          ['Colours',  'Full bed · Gray · Full colour blend'],
