  },
  {
    id: 'pier-caps',
    num: '09',
    label: 'Limestone · Finishing',
    title: 'Pier Caps',
    imageSrc: '/pictures/Limestone%20page%20images/Pier%20Caps.jpg',
    imageAlt: 'Indiana limestone pier caps on garden wall entrance, residential exterior, Tulip Precast',
    imagePosition: 'center 40%',
    description: 'Available in 2¼" and 3" thicknesses as well as a variety of lengths and widths to meet your needs, our limestone pier caps are available in rock face or square edge finishes. We offer pier caps in Full Colour Blend (FCB) and Gray — providing timeless options for residential and commercial applications.',
    specs: [
      ['Thicknesses',  '2¼" and 3"'],
      ['Finishes',     'Rock Face · Square Edge'],
      ['Colours',      'Full Colour Blend (FCB) · Gray'],
      ['Availability', 'Standard and custom lengths and widths'],
    ],
  },
  {
    id: 'quoins',
    num: '10',
    label: 'Limestone · Masonry',
    title: 'Quoins',
    imageSrc: '/pictures/Limestone%20page%20images/Quoins.jpg',
    imageAlt: 'Indiana limestone classic quoin, corner block profile, Tulip Precast Brampton',
    imagePosition: 'center center',
    description: 'Simple and classic, quoins create a wonderful visual contrast to masonry veneer. These can be installed one on top of the other or divided by another form of exterior cladding. Versatile in application, quoins add definition, permanence, and elegance to any corner — residential or commercial.',
    variants: [
      { name: 'Classic Quoin',              description: 'Single piece corner block, clean and bold',    imageSrc: '/pictures/Quoins/classic%20Quoin.png' },
      { name: 'Double Chamfered',           description: 'Angled edges both sides, refined shadow',     imageSrc: '/pictures/Quoins/double%20chamfered.png' },
      { name: 'Classic Two Piece',          description: 'Split into two for flexible installation',     imageSrc: '/pictures/Quoins/classic%20Two%20Piece.png' },
      { name: 'Double Chamfered Two Piece', description: 'Chamfered profile in two-piece format',       imageSrc: '/pictures/Quoins/Double%20Chamfered%20Two%20Piece.png' },
      { name: 'Classic Two Piece Mitered',  description: 'Mitered joint for seamless corner wrap',      imageSrc: '/pictures/Quoins/Classic%20Two%20Piece%20Mitered.png' },
    ],
  },
  {
    id: 'sills',
    num: '11',
    label: 'Limestone · Architectural',
    title: 'Sills',
    imageSrc: '/pictures/Limestone%20page%20images/sills.png',
    imageAlt: 'Indiana limestone classic slip sill profile, Tulip Precast',
    imagePosition: 'center center',
    description: 'Sills are among the most essential architectural elements — adding understated style to any project. Slip sills are designed to align seamlessly with the width of the masonry opening. Lug sills extend beyond the window, allowing for the installation of a full surround and a more pronounced architectural presence. Custom sills are also available.',
    callout: {
      label: 'Slip Sill vs Lug Sill',
      body: 'Slip sills sit flush within the masonry opening. Lug sills project beyond the window frame — use a lug sill when installing a full surround system for the most architecturally complete result.',
