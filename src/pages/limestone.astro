<script>
  /* ── Sticky subnav active state ───────────────────────────── */
  (function () {
    const sections = Array.from(document.querySelectorAll<HTMLElement>('.cat-section[id]'));
    const navLinks  = Array.from(document.querySelectorAll<HTMLElement>('.product-subnav a[href^="#"]'));
    const OFFSET    = 150;

    if (!sections.length || !navLinks.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle(
                'is-active',
                link.getAttribute('href') === '#' + id
              );
            });
            const activeLink = document.querySelector<HTMLElement>('.product-subnav a.is-active');
            activeLink?.scrollIntoView({
              behavior: 'smooth',
              block: 'nearest',
              inline: 'center',
            });
          }
        });
      },
      {
        rootMargin: `-${OFFSET}px 0px -50% 0px`,
        threshold: 0,
      }
    );

    sections.forEach((s) => observer.observe(s));
  })();
</script>

<script>
