---

<BaseLayout
  title="Limestone & Precast Portfolio | GTA Projects | Tulip"
  description="Portfolio of Indiana Limestone and precast projects across the GTA — residential, commercial, and custom stonework. Serving Brampton, Oakville, Toronto."
  pageClass="page-portfolio"
  solidNav={true}
  loadPortfolioFilter={true}
>

  <Hero
    size="xs"
    imageSrc="/pictures/hero%20image.jpg"
    imageAlt="Indiana limestone portfolio — residential and commercial projects across Canada & USA"
    headline="Our Portfolio."
    headlineItalic="Projects Built to Last."
    eyebrow="RESIDENTIAL · COMMERCIAL · INDUSTRIAL · CUSTOM"
    primaryCTA="REQUEST A QUOTE"
    primaryCTAHref="/contact"
  />

  <!-- Filter bar -->
  <div
    class="port-filter-bar"
    role="toolbar"
    aria-label="Filter projects by category"
  >
    <div class="port-filter-inner">

      {filterOptions.map(opt => (
        <button
          class:list={[
            'portfolio-filter-btn',
            { 'is-active': opt.value === 'all' }
          ]}
          data-filter={opt.value}
          type="button"
          aria-pressed={opt.value === 'all' ? 'true' : 'false'}
        >
          {opt.label}
        </button>
      ))}

      <span
        class="port-filter-count"
        id="portfolio-count"
        aria-live="polite"
        aria-atomic="true"
      >
        {projects.length} projects
      </span>

    </div>
  </div>

  <!-- Project grid -->
  <section class="port-main" aria-label="Portfolio projects">
    <div class="port-container">

      <div
        class="port-grid"
        id="portfolio-grid"
      >
        {projects.map((project, index) => (
          <ProjectCard
            project={project}
            index={index}
            size={project.featured ? 'featured' : 'normal'}
          />
        ))}
      </div>

      <!-- Empty state -->
      <div
        class="port-empty"
        id="portfolio-empty"
        hidden
        aria-live="polite"
      >
        <p class="port-empty-text">
          No projects in this category yet.
        </p>
        <button
          class="btn btn-outlined-dark"
          data-filter="all"
          type="button"
        >
          View All Projects
        </button>
      </div>

      <!-- Bottom row -->
      <div class="port-bottom">
        <p class="port-bottom-note">
          More projects available on request — contact us to discuss
          your specific style and requirements.
        </p>
        <a
          href="/contact"
          class="btn btn-primary btn-magnetic"
        >
          Start Your Project →
        </a>
      </div>

    </div>
  </section>

  <!-- Project viewer — renders all data, shown on demand -->
  <ProjectViewer projects={projects} />

</BaseLayout>

<style>

  /* ── Filter bar ─────────────────────────────────────────────── */

  .port-filter-bar {
    position: sticky;
    top: var(--nav-height, 72px);
    z-index: 80;
    background: var(--white-warm);
    border-bottom: 1px solid var(--cream-dark);
    border-top: 1px solid var(--cream-dark);
  }

  .port-filter-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .port-filter-inner::-webkit-scrollbar { display: none; }

  .portfolio-filter-btn {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 400;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--stone-light);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 16px 18px;
    cursor: pointer;
    white-space: nowrap;
    transition:
      color 200ms ease,
      border-color 200ms ease;
  }

  .portfolio-filter-btn:hover {
    color: var(--stone-dark);
  }

  .portfolio-filter-btn.is-active {
    color: var(--warm-sand);
    border-bottom-color: var(--warm-sand);
  }

  .portfolio-filter-btn:focus-visible {
    outline: 2px solid var(--focus-ring, #C8A882);
    outline-offset: -2px;
  }

  .port-filter-count {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 300;
    color: var(--stone-lighter, #C4B8B0);
    letter-spacing: 0.05em;
    margin-left: auto;
    padding: 16px 0;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Main ───────────────────────────────────────────────────── */

  .port-main {
    padding: var(--space-xl) 0 var(--space-2xl);
    background: var(--limestone-cream);
  }

  .port-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
  }

  /* ── Portfolio grid — 4 cols on desktop, stepping down ──────── */

  .port-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    align-items: start;
  }

  /* ── Empty state — hidden by default, flex when visible ─────── */

  .port-empty {
    display: none;
  }

  .port-empty:not([hidden]) {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
    padding: var(--space-2xl) 0;
  }

  .port-empty-text {
    font-family: var(--font-serif);
    font-size: var(--text-title);
    font-weight: 300;
    font-style: italic;
    color: var(--stone-light);
  }

  /* ── Bottom row ─────────────────────────────────────────────── */

  .port-bottom {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--cream-dark);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .port-bottom-note {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    color: var(--stone-light);
    max-width: 48ch;
  }

  /* ── Responsive ─────────────────────────────────────────────── */

  @media (max-width: 1200px) {
    .port-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .port-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .port-grid { grid-template-columns: 1fr; }
    .port-bottom {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .port-bottom-note { max-width: none; }
  }

</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.tulipprecast.com" },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": "https://www.tulipprecast.com/portfolio" }
  ]
}
</script>
