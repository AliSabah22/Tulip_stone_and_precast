---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import ProjectViewer from '../components/portfolio/ProjectViewer.astro';

interface ProjectImage {
  src: string;
  alt: string;
  caption?: string;
  position?: string;
}

interface Project {
  id: string;
  title: string;
  style: string;
  location: string;
  year: string;
  categories: string[];
  heroImage: ProjectImage;
  images: ProjectImage[];
  materials: string[];
  description: string;
  featured?: boolean;
}

/*
 * ─────────────────────────────────────────────────────────────
 * HOW TO ADD A NEW PROJECT
 * ─────────────────────────────────────────────────────────────
 *
 * 1. Add photos to public/pictures/portofolio images/
 *    Name them clearly: project-name-1.jpg, project-name-2.jpg
 *    Aim for 2–4 photos per project (exterior, detail, material)
 *
 * 2. Append a new object to the `projects` array below.
 *    Copy an existing entry as your template.
 *
 * 3. Required fields:
 *    id          — unique slug, lowercase, hyphens only
 *    title       — display name shown in card and viewer
 *    style       — architectural style e.g. "Neoclassical"
 *    location    — city and province only, never full address
 *    year        — four-digit string e.g. "2025"
 *    categories  — one or more of: "residential" "commercial"
 *                  "limestone" "precast" "custom"
 *    heroImage   — the image shown in the grid card
 *    images      — all images including the hero (for the viewer)
 *    materials   — list of Tulip products used on this project
 *    description — 2–3 sentence project summary
 *
 * 4. Optional:
 *    featured: true — makes the card taller in the masonry grid
 *
 * 5. Save the file. Run: npm run build
 *    The project appears automatically everywhere:
 *    grid card, filter system, viewer panel, URL deep-link.
 *    No other files need to change.
 * ─────────────────────────────────────────────────────────────
 */

