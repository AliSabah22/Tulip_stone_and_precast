---
export interface Props {
  label?: string;
  title: string;
  titleItalic?: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const {
  label,
  title,
  titleItalic,
  subtitle,
  align = 'left',
} = Astro.props;
---

<div class={`section-header section-header--${align} reveal`}>
  {label && <p class="section-label">{label}</p>}
  <h2 class="section-title">
    {title}
    {titleItalic && <em class="section-title-italic"> {titleItalic}</em>}
  </h2>
  <div class="section-rule draw-line" aria-hidden="true"></div>
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
</div>

<style>
  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-header--center {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-label {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--warm-sand);
    margin-bottom: var(--space-xs);
    max-width: none;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 400;
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-tight);
    color: var(--stone-dark);
    margin-bottom: var(--space-md);
  }

  .section-title-italic {
    font-style: italic;
    color: var(--stone-mid);
  }

  .section-rule {
    width: 40px;
    height: 1px;
    background: var(--warm-sand);
    margin-bottom: var(--space-md);
  }

  .section-header--center .section-rule {
    margin-left: auto;
    margin-right: auto;
  }

  .section-subtitle {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 300;
    line-height: var(--lh-body);
    color: var(--stone-mid);
    max-width: 60ch;
  }

  .section-header--center .section-subtitle {
    text-align: center;
  }
</style>
