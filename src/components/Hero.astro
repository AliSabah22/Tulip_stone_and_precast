---
export interface Props {
  eyebrow?: string;
  headline: string;
  headlineItalic?: string;
  subheading?: string;
  primaryCTA?: string;
  primaryCTAHref?: string;
  secondaryCTA?: string;
  secondaryCTAHref?: string;
  backgroundGradient?: string;
  imageSrc?: string;
  imageAlt?: string;
  videoSrc?: string;
  posterSrc?: string;
  size?: 'full' | 'short' | 'xs';
  accentCount?: string;
  accentLabel?: string;
}

const {
  eyebrow,
  headline,
  headlineItalic,
  subheading,
  primaryCTA,
  primaryCTAHref = '/contact',
  secondaryCTA,
  secondaryCTAHref = '/portfolio',
  backgroundGradient = 'var(--grad-hero)',
  imageSrc,
  imageAlt = '',
  videoSrc,
  posterSrc,
  size = 'full',
  accentCount = '500+',
  accentLabel = 'PROJECTS',
} = Astro.props;

const sizeClass = size === 'full' ? '' : size === 'short' ? 'hero--short' : 'hero--xs';
---

<section class={`hero ${sizeClass}`} aria-label="Page hero">

  <!-- Background: video > image > gradient (priority order) -->
  <div
    class="hero-bg grad-hero"
    style={videoSrc || imageSrc ? '' : `background: ${backgroundGradient}`}
    aria-hidden="true"
  >
    {videoSrc ? (
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
        preload="auto"
        poster={posterSrc}
      >
        <source src={videoSrc} type="video/mp4" />
      </video>
    ) : imageSrc ? (
      <img
        src={imageSrc}
        alt={imageAlt}
        width="1920"
        height="1080"
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
    ) : (
      <div class="hero-gradient-bg" style={`background: ${backgroundGradient}`}></div>
    )}
  </div>

  <!-- Particles canvas (loaded by particles-init.js when present) -->
  {size === 'full' && <canvas id="hero-canvas" aria-hidden="true"></canvas>}

  <!-- Overlay -->
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="hero-content">
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}

    <h1 class="hero-headline">
      {headline}
      {headlineItalic && (
        <>
          <br />
          <em class="hero-italic">{headlineItalic}</em>
        </>
      )}
    </h1>

    {subheading && <p class="hero-sub">{subheading}</p>}

    {(primaryCTA || secondaryCTA) && (
      <div class="hero-cta">
        {primaryCTA && (
          <a href={primaryCTAHref} class="btn btn-primary btn-magnetic">
            {primaryCTA}
          </a>
        )}
        {secondaryCTA && (
          <a href={secondaryCTAHref} class="btn btn-outlined">
            {secondaryCTA}
          </a>
        )}
      </div>
    )}
  </div>

  <!-- Scroll indicator (full hero only) -->
  {size === 'full' && (
    <div class="hero-scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
      <span class="scroll-label">SCROLL</span>
    </div>
  )}

  <!-- Right accent (full hero only) -->
  {size === 'full' && (
    <div class="hero-right-accent" aria-hidden="true">
      <div class="accent-line"></div>
      <span class="accent-count">{accentCount}</span>
      <span class="accent-label">{accentLabel}</span>
    </div>
  )}
</section>

<style>
  /* Video fills background exactly like an image */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 1;
  }

  .hero-gradient-bg {
    position: absolute;
    inset: 0;
  }

  /* Reduce motion: pause video, show poster instead */
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none;
    }
    .hero-poster {
      z-index: 1;
    }
  }
</style>
