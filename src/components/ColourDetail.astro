---
export interface Colour {
  id: string;
  name: string;
  family: string;
  hex: string;
  imageSrc: string;
  imageAlt: string;
  description: string;
  characteristics: string[];
  bestFor: string[];
  pairsWith: string;
}

export interface Props {
  colour: Colour;
  isFirst?: boolean;
}

const { colour, isFirst = false } = Astro.props;
---

<div
  class:list={['cd', isFirst && 'cd--active']}
  data-colour-panel={colour.id}
  aria-hidden={isFirst ? 'false' : 'true'}
  role="region"
  aria-label={`${colour.name} colour information`}
>
  <!-- Photo column -->
  <div class="cd-photo">
    <img
      src={colour.imageSrc}
      alt={colour.imageAlt}
      width="900"
      height="600"
      loading="lazy"
      decoding="async"
      class="cd-img"
    />
    <div class="cd-photo-meta" aria-hidden="true">
      <span class="cd-family-pill">{colour.family} Family</span>
      <div class="cd-hex-row">
        <span class="cd-hex-dot" style={`background: ${colour.hex}`}></span>
        <span class="cd-hex-code">{colour.hex}</span>
      </div>
    </div>
    <div class="cd-photo-corner" aria-hidden="true"></div>
  </div>

  <!-- Info column -->
  <div class="cd-info">

    <header class="cd-header">
      <p class="cd-eyebrow">Indiana Limestone · Natural Stone</p>
      <h2 class="cd-name">{colour.name}</h2>
      <div class="cd-rule" aria-hidden="true"></div>
    </header>

    <p class="cd-description">{colour.description}</p>

    <div class="cd-section">
      <h3 class="cd-section-title">Stone Character</h3>
      <ul class="cd-list" role="list">
        {colour.characteristics.map((c) => (
          <li class="cd-list-item">
            <span class="cd-dash" aria-hidden="true">—</span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="cd-section">
      <h3 class="cd-section-title">Best Applications</h3>
      <ul class="cd-list" role="list">
        {colour.bestFor.map((use) => (
          <li class="cd-list-item">
            <span class="cd-dash" aria-hidden="true">—</span>
            <span>{use}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="cd-pairs">
      <span class="cd-pairs-label">Pairs with</span>
      <p class="cd-pairs-text">{colour.pairsWith}</p>
    </div>

    <div class="cd-availability" aria-label="Veneer availability">
      <span class="cd-avail-icon" aria-hidden="true">●</span>
      Available in all five veneer types — thin bed and full bed depth
    </div>

    <div class="cd-actions">
      <a
        href="/contact?subject=sample-request"
        class="btn btn-primary btn-magnetic"
      >
        Request a Sample
      </a>
      <a href="/limestone" class="btn btn-outlined-dark">
        View Products →
      </a>
    </div>

  </div>
</div>

<style>
  /* ── Panel visibility ─────────────────────────────────── */

  .cd {
    display: none;
  }

  .cd--active {
    display: grid;
    grid-template-columns: 55fr 45fr;
    min-height: 520px;
    border: 1px solid var(--cream-dark);
    background: var(--white-warm);
    animation: cdFadeUp 0.45s var(--ease-out) both;
  }

  @keyframes cdFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Photo column ─────────────────────────────────────── */

  .cd-photo {
    position: relative;
    overflow: hidden;
    background: var(--quarry-stone);
  }

  .cd-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 700ms var(--ease-out);
  }

  .cd--active:hover .cd-img {
    transform: scale(1.03);
  }

  .cd-photo-meta {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cd-family-pill {
    display: inline-flex;
    align-items: center;
    background: rgba(30, 26, 23, 0.72);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(200, 168, 130, 0.3);
    color: var(--warm-sand);
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    padding: 5px 12px;
    align-self: flex-start;
  }

  .cd-hex-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .cd-hex-dot {
    width: 14px;
    height: 14px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .cd-hex-code {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--ls-wide);
    color: rgba(253, 250, 246, 0.65);
    text-transform: uppercase;
  }

  .cd-photo-corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-top: 40px solid var(--warm-sand);
    border-left: 40px solid transparent;
    opacity: 0.6;
  }

  /* ── Info column ──────────────────────────────────────── */

  .cd-info {
    padding: var(--space-xl) var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    overflow-y: auto;
  }

  /* ── Header ───────────────────────────────────────────── */

  .cd-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cd-eyebrow {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
    max-width: none;
  }

  .cd-name {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 300;
    color: var(--stone-dark);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
  }

  .cd-rule {
    width: 36px;
    height: 1px;
    background: var(--warm-sand);
    margin-top: var(--space-xs);
  }

  /* ── Description ──────────────────────────────────────── */

  .cd-description {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    font-weight: 300;
    color: var(--stone-mid);
    line-height: var(--lh-body);
    max-width: 50ch;
  }

  /* ── Sections ─────────────────────────────────────────── */

  .cd-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cd-section-title {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--stone-dark);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--cream-dark);
  }

  .cd-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cd-list-item {
    display: flex;
    gap: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    color: var(--stone-mid);
    line-height: 1.5;
    max-width: none;
  }

  .cd-dash {
    color: var(--warm-sand);
    flex-shrink: 0;
    font-weight: 400;
  }

  /* ── Pairs with ───────────────────────────────────────── */

  .cd-pairs {
    background: var(--sand-pale);
    border-left: 2px solid var(--warm-sand);
    padding: var(--space-sm) var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cd-pairs-label {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--warm-sand);
  }

  .cd-pairs-text {
    font-family: var(--font-serif);
    font-size: var(--text-body);
    font-weight: 400;
    font-style: italic;
    color: var(--stone-dark);
    line-height: var(--lh-heading);
    max-width: none;
  }

  /* ── Availability ─────────────────────────────────────── */

  .cd-availability {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    color: var(--stone-mid);
    max-width: none;
  }

  .cd-avail-icon {
    color: var(--sage-green);
    font-size: 8px;
    flex-shrink: 0;
  }

  /* ── Actions ──────────────────────────────────────────── */

  .cd-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: var(--space-sm);
    border-top: 1px solid var(--cream-dark);
  }

  /* ── Responsive ───────────────────────────────────────── */

  @media (max-width: 1024px) {
    .cd--active {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .cd-photo {
      aspect-ratio: 16 / 9;
    }

    .cd-info {
      padding: var(--space-lg);
    }
  }

  @media (max-width: 640px) {
    .cd-name {
      font-size: var(--text-title);
    }

    .cd-description {
      max-width: none;
    }

    .cd-actions {
      flex-direction: column;
    }

    .cd-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
