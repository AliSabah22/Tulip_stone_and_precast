---
export interface Stat {
  number: number;
  suffix: string;
  label: string;
}

export interface Props {
  stats?: Stat[];
}

const {
  stats = [
    { number: 25,  suffix: '+',  label: 'Years of Craftsmanship' },
    { number: 500, suffix: '+',  label: 'Projects Completed' },
    { number: 25,  suffix: '',   label: 'Stone Colours' },
    { number: 100, suffix: '%',  label: 'Ontario Made' },
  ],
} = Astro.props;
---

<section class="trust-bar" aria-label="Key statistics">
  <div class="trust-bar-grid">
    {stats.map((stat, i) => (
      <div class={`stat-item ${i < stats.length - 1 ? 'stat-item--bordered' : ''}`}>
        <p class="stat-number">
          <span
            data-count-up
            data-target={stat.number}
            data-suffix={stat.suffix}
            aria-label={`${stat.number}${stat.suffix}`}
          >{stat.number}{stat.suffix}</span>
        </p>
        <p class="stat-label">{stat.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .trust-bar {
    background: var(--warm-sand);
    border-top: 1px solid rgba(200, 168, 130, 0.3);
    border-bottom: 1px solid rgba(200, 168, 130, 0.3);
  }

  .trust-bar-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 4px;
    padding: var(--space-lg) var(--space-md);
  }

  .stat-item--bordered {
    border-right: 1px solid rgba(61, 53, 48, 0.12);
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 300;
    line-height: 1;
    letter-spacing: var(--ls-tight);
    color: var(--quarry-stone);
    max-width: none;
  }

  .stat-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--stone-dark);
    opacity: 0.7;
    max-width: none;
  }

  @media (max-width: 640px) {
    .trust-bar-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-item:nth-child(2) {
      border-right: none;
    }

    .stat-item:nth-child(1),
    .stat-item:nth-child(2) {
      border-bottom: 1px solid rgba(61, 53, 48, 0.12);
    }
  }
</style>
