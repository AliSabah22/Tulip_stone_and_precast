---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">

    <!-- Column 1: Brand -->
    <div class="footer-col footer-col--brand">
      <a class="footer-logo" href="/">
        TULIP <span class="footer-logo-dot">·</span> LIMESTONE · PRECAST
      </a>
      <p class="footer-tagline">Crafted by Nature. Perfected by Design.</p>

      <!-- Ontario Made badge -->
      <div class="ontario-made-badge" aria-label="Ontario Made certified">
        <svg width="80" height="32" viewBox="0 0 80 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="0.5" y="0.5" width="79" height="31" stroke="#9C8880" stroke-width="1"/>
          <text x="40" y="12" font-family="Jost, sans-serif" font-size="6" font-weight="400" fill="#9C8880" text-anchor="middle" letter-spacing="2">ONTARIO</text>
          <text x="40" y="22" font-family="Jost, sans-serif" font-size="8" font-weight="400" fill="#C8A882" text-anchor="middle" letter-spacing="3">MADE</text>
        </svg>
      </div>

      <!-- Social icons -->
      <div class="footer-social" aria-label="Social media links">
        <a href="https://www.instagram.com/tulipstone_and_precast/" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
        </a>
        <a href="https://www.facebook.com/tulipprecast.ca/" class="social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/company/tulip-precast-inc/?originalSubdomain=ca" class="social-link" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="2" stroke="currentColor" stroke-width="1.2"/>
            <path d="M7 10v7M7 7v.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            <path d="M11 17v-4a2 2 0 014 0v4M11 10v7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Column 2: Products -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Products</h3>
      <ul class="footer-links" role="list">
        <li><a href="/limestone">Limestone Products</a></li>
        <li><a href="/precast">Precast Products</a></li>
        <li><a href="/gfrc">GFRC Panels</a></li>
        <li><a href="/services">Custom Services</a></li>
        <li><a href="/colours">Colours &amp; Finishes</a></li>
      </ul>
    </div>

    <!-- Column 3: Company -->
    <div class="footer-col">
      <h3 class="footer-col-heading">Company</h3>
      <ul class="footer-links" role="list">
        <li><a href="/about">About Tulip</a></li>
        <li><a href="/about#process">Our Process</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/about#ordering">Ordering Information</a></li>
      </ul>
    </div>

    <!-- Column 4: Contact -->
    <div class="footer-col footer-col--contact">
      <h3 class="footer-col-heading">Contact</h3>
      <address class="footer-address">
        <a href="mailto:office@tulipprecast.com">office@tulipprecast.com</a>
        <a href="tel:6475347755">647-534-7755</a>
<a href="tel:9057960110">905-796-0110</a>
        <a href="https://www.google.com/maps/place/Tulip+Stone+and+Precast/data=!4m2!3m1!1s0x0:0x6a48582350b20292?sa=X&ved=1t:2428&ictx=111" target="_blank" rel="noopener noreferrer">
          98 Rutherford Rd Unit 2C<br />
          Brampton, ON L6W 3J5
        </a>
      </address>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-copyright">
      &copy; {year} Tulip Limestone · Precast. All rights reserved.
    </p>
    <p class="footer-ontario">Ontario Made · Brampton, ON · Canada</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--quarry-dark);
    padding: var(--space-2xl) 0 0;
    border-top: 1px solid rgba(200, 168, 130, 0.1);
  }

  .footer-grid {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: var(--space-2xl);
  }

  .footer-col-heading {
    font-family: var(--font-sans);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--stone-light);
    margin-bottom: var(--space-md);
  }

  .footer-logo {
    font-family: var(--font-serif);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--white-warm);
    display: inline-block;
    margin-bottom: var(--space-sm);
    transition: color 150ms;
  }

  .footer-logo:hover { color: var(--warm-sand); }
  .footer-logo-dot { color: var(--warm-sand); }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-small);
    font-weight: 300;
    font-style: italic;
    color: var(--stone-light);
    margin-bottom: var(--space-md);
    max-width: none;
  }

  .ontario-made-badge {
    margin-bottom: var(--space-md);
    display: inline-block;
  }

  .footer-social {
    display: flex;
    gap: var(--space-sm);
  }

  .social-link {
    color: var(--stone-light);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .social-link:hover { color: var(--warm-sand); }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-links a {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    color: var(--stone-light);
    letter-spacing: 0.03em;
    transition: color var(--duration-fast) var(--ease-out);
    display: inline-block;
    padding: 2px 0;
  }

  .footer-links a:hover { color: var(--warm-sand); }

  .footer-address {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    font-style: normal;
  }

  .footer-address a,
  .footer-address span {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 300;
    color: var(--stone-light);
    letter-spacing: 0.03em;
    line-height: var(--lh-body);
  }

  .footer-address a {
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-address a:hover { color: var(--warm-sand); }

  .footer-bottom {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-lg) var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(156, 136, 128, 0.12);
    margin-top: var(--space-2xl);
  }

  .footer-copyright,
  .footer-ontario {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 300;
    color: rgba(156, 136, 128, 0.5);
    letter-spacing: var(--ls-wide);
    max-width: none;
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-xs);
      text-align: center;
    }
  }
</style>
